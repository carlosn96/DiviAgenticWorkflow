# Configuración del entorno del Proyecto local `divitheme`
# Copia este archivo como `.env` en la raíz del proyecto (`c:\Users\CORE I9\Local Sites\divitheme`)
# y completa los valores reales.

# ==========================================
# 1. Comandos de Entorno (CLI Wrappers)
# ==========================================
WP_CLI_COMMAND=DAW_bundle\wp.bat
PHP_CLI_COMMAND=.\php.bat
MYSQL_CLI_COMMAND=.\mysql.bat

# ==========================================
# 2. Rutas Estructurales
# ==========================================
PROJECT_ROOT=.
WORKSPACE_DIR=DAW_bundle/workspace

# ==========================================
# 3. MySQL Local (requiere mysql.bat)
# ==========================================
LOCAL_DB_NAME=local
LOCAL_DB_USER=root
LOCAL_DB_PASS=root
LOCAL_DB_HOST=127.0.0.1
LOCAL_DB_PORT=10037
MYSQL_BIN=...\mysql.exe

# ==========================================
# 4. Theme Builder local (obtener IDs de WP Admin > Theme Builder)
# ==========================================
DAW_HEADER_ID=
DAW_FOOTER_ID=

# ==========================================
# 5. Prefijo de tabla local (desde wp-config.php)
# ==========================================
LOCAL_DB_TABLE_PREFIX=wp_

# ==========================================
# 6. REMOTO - No usar por defecto (solo cuando se valide servidor)
# ==========================================
# DAW_DB_TABLE_PREFIX=fxr_
