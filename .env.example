# Configuración del entorno del Proyecto DAW (Divi Agentic Workflow)
# Renombra o copia este archivo como ".env" en la raíz de tu proyecto donde vayas a operar

# ==========================================
# 1. Comandos de Entorno (CLI Wrappers)
# ==========================================
# En ambientes tipo "Local WP" se suelen usar wrappers específicos (ej. wp.bat, php.bat).
WP_CLI_COMMAND=.\wp.bat
PHP_CLI_COMMAND=.\php.bat
MYSQL_CLI_COMMAND=.\mysql.bat

# En ambientes estándar (Global WP-CLI, macOS/Linux, XAMPP, Docker) descomenta esto:
# WP_CLI_COMMAND=wp
# PHP_CLI_COMMAND=php
# MYSQL_CLI_COMMAND=mysql

# ==========================================
# 2. Rutas Estructurales
# ==========================================
# Raíz del ecosistema (donde se ubica tu WordPress y/o los comandos wp)
PROJECT_ROOT="."

# Carpeta de los schemas
WORKSPACE_DIR="workspace"
