{
  "presets": ["section:light"],
  "decoration": {
    "spacing": {
      "desktop": { "value": { "padding": { "top": "120px", "bottom": "120px", "right": "96px", "left": "96px" } } },
      "tablet": { "value": { "padding": { "top": "80px", "bottom": "80px", "right": "48px", "left": "48px" } } },
      "phone": { "value": { "padding": { "top": "56px", "bottom": "56px", "right": "24px", "left": "24px" } } }
    }
  },
  "rows": [
    {
      "column_structure": "3_5,2_5",
      "columns": [
        {
          "type": "3_5",
          "modules": [
            {
              "type": "divi/text",
              "presets": ["text:eyebrow-dark"],
              "content": "<p>{{slot:eyebrow}}</p>"
            },
            {
              "type": "divi/heading",
              "presets": ["text:display-md"],
              "decoration": {
                "spacing": {
                  "desktop": { "value": { "padding": { "bottom": "24px" } } }
                }
              },
              "content": "<h2>{{slot:title}}</h2>"
            },
            {
              "type": "divi/text",
              "presets": ["text:lead"],
              "decoration": {
                "spacing": {
                  "desktop": { "value": { "padding": { "bottom": "24px" } } }
                }
              },
              "content": "<p>{{slot:text}}</p>"
            },
            {
              "type": "divi/text",
              "presets": ["text:body-md"],
              "content": "<p>{{slot:body}}</p>"
            },
            {
              "type": "divi/button",
              "presets": ["module:btn-primary"],
              "decoration": {
                "spacing": {
                  "desktop": { "value": { "padding": { "top": "16px" } } }
                }
              },
              "button_text": "{{slot:btn_primary_text}}",
              "button_url": "{{slot:btn_primary_url}}"
            }
          ]
        },
        {
          "type": "2_5",
          "modules": [
            {
              "type": "divi/blurb",
              "presets": ["module:glass-card", "transform:hover-lift"],
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": { "top": "40px", "bottom": "40px", "right": "32px", "left": "32px" }
                    }
                  }
                }
              },
              "title": "",
              "icon": "{{slot:media_icon}}",
              "content": "<p>{{slot:media_attribution}}</p>"
            }
          ]
        }
      ]
    }
  ]
}
