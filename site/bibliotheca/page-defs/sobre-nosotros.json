            {"type": "divi/blurb", "presets": ["module:card"],
             "title": "Mtro. Ricardo L&oacute;pez",
             "content": "<p>Coordinador de Investigaci&oacute;n</p><p>Maestro en Historia por el COLMEX. L&iacute;nea de investigaci&oacute;n en archivos digitales.</p>",
             "icon": "&#xe0b4;",
             "decoration": {"animation": {"desktop": {"value": {"style": "fade", "duration": "480ms", "delay": "100ms"}}}}},
            {"type": "divi/blurb", "presets": ["module:card"],
