{
  "title": "Contacto",
  "slug": "contacto",
  "description": "Formulario de contacto e información de la Biblioteca",
  "sections": [
    {
      "presets": ["section:hero-dark"],
      "bg_gradient": {
        "type": "linear", "direction": "180deg", "overlaysImage": "off",
        "stops": [
          {"color": "rgba(26,24,20,0.92)", "position": "0"},
          {"color": "rgba(45,42,37,0.88)", "position": "100"}
        ]
      },
      "rows": [
        {
          "column_structure": "4_4",
          "modules": [
            {"type": "divi/text", "presets": ["text:eyebrow-dark"],
             "content": "<p>CONTACTO</p>",
             "decoration": {"spacing": {"desktop": {"value": {"padding": {"bottom": "24px"}}}}}},
            {"type": "divi/heading", "presets": ["text:hero-title"],
             "content": "<h1>Estamos para servirte</h1>",
             "decoration": {"spacing": {"desktop": {"value": {"padding": {"bottom": "40px"}}}}}},
            {"type": "divi/text", "presets": ["text:lead"],
             "content": "<p>Resolvemos tus dudas en menos de 24 horas. Tambi&eacute;n puedes visitarnos en nuestra sede.</p>",
             "decoration": {"sizing": {"desktop": {"value": {"width": "560px"}}}}}
          ]
        }
      ]
    },
    {
      "presets": ["section:light"],
      "rows": [
        {
          "column_structure": "1_2,1_2",
          "modules": [
            {"type": "divi/group",
             "decoration": {
               "background": {"desktop": {"value": {"color": "{{design:color:surface-white}}"}}},
               "border": {"desktop": {"value": {
                 "radius": {"sync": "on", "topLeft": "{{design:radius:lg}}", "topRight": "{{design:radius:lg}}", "bottomRight": "{{design:radius:lg}}", "bottomLeft": "{{design:radius:lg}}"}}}},
               "spacing": {"desktop": {"value": {"padding": "40px"}}}},
             "children": [
              {"type": "divi/text",
               "content": "<h2>Enviar mensaje</h2>",
               "headingFont": {"h2": {"font": {"desktop": {"value": {
                 "fontFamily": "{{design:font:display}}", "size": "28px", "weight": "500",
                 "color": "{{design:color:ink}}", "lineHeight": "1.2"}}}}},
               "decoration": {"spacing": {"desktop": {"value": {"padding": {"bottom": "24px"}}}}}},
              {"type": "divi/text",
               "content": "<p>Nombre completo</p><p>Correo electr&oacute;nico</p><p>Asunto</p><p>Mensaje</p>",
               "bodyFont": {"body": {"font": {"desktop": {"value": {
                 "fontFamily": "{{design:font:body}}", "size": "16px",
                 "color": "{{design:color:parchment-700}}"}}}}},
               "decoration": {"spacing": {"desktop": {"value": {"padding": {"bottom": "24px"}}}}}},
              {"type": "divi/button", "presets": ["module:btn-primary"],
               "button_text": "ENVIAR MENSAJE",
               "button_url": "#"}
             ]},
            {"type": "divi/group",
             "decoration": {
               "background": {"desktop": {"value": {"color": "{{design:color:surface-white}}"}}},
               "border": {"desktop": {"value": {
                 "radius": {"sync": "on", "topLeft": "{{design:radius:lg}}", "topRight": "{{design:radius:lg}}", "bottomRight": "{{design:radius:lg}}", "bottomLeft": "{{design:radius:lg}}"}}}},
               "spacing": {"desktop": {"value": {"padding": "40px"}}}},
             "children": [
              {"type": "divi/text",
               "content": "<h2>Informaci&oacute;n</h2>",
               "headingFont": {"h2": {"font": {"desktop": {"value": {
                 "fontFamily": "{{design:font:display}}", "size": "28px", "weight": "500",
                 "color": "{{design:color:ink}}", "lineHeight": "1.2"}}}}},
               "decoration": {"spacing": {"desktop": {"value": {"padding": {"bottom": "32px"}}}}}},
              {"type": "divi/text",
               "content": "<h4>Direcci&oacute;n</h4><p>Av. de los Insurgentes 1234, Col. Del Valle, Ciudad de M&eacute;xico</p>",
               "headingFont": {"h4": {"font": {"desktop": {"value": {
                 "fontFamily": "{{design:font:ui}}", "size": "11px", "weight": "500",
                 "textTransform": "uppercase", "letterSpacing": "0.08em",
                 "color": "{{design:color:accent}}"}}}}},
               "bodyFont": {"body": {"font": {"desktop": {"value": {
                 "fontFamily": "{{design:font:body}}", "size": "16px",
                 "color": "{{design:color:parchment-700}}"}}}}},
               "decoration": {"spacing": {"desktop": {"value": {"padding": {"bottom": "24px"}}}}}},
              {"type": "divi/text",
               "content": "<h4>Tel&eacute;fono</h4><p>+52 (55) 1234 5678</p>",
               "headingFont": {"h4": {"font": {"desktop": {"value": {
                 "fontFamily": "{{design:font:ui}}", "size": "11px", "weight": "500",
                 "textTransform": "uppercase", "letterSpacing": "0.08em",
                 "color": "{{design:color:accent}}"}}}}},
               "bodyFont": {"body": {"font": {"desktop": {"value": {
                 "fontFamily": "{{design:font:body}}", "size": "16px",
                 "color": "{{design:color:parchment-700}}"}}}}},
               "decoration": {"spacing": {"desktop": {"value": {"padding": {"bottom": "24px"}}}}}},
              {"type": "divi/text",
               "content": "<h4>Correo</h4><p>contacto@bibliotheca.mx</p>",
               "headingFont": {"h4": {"font": {"desktop": {"value": {
                 "fontFamily": "{{design:font:ui}}", "size": "11px", "weight": "500",
                 "textTransform": "uppercase", "letterSpacing": "0.08em",
                 "color": "{{design:color:accent}}"}}}}},
               "bodyFont": {"body": {"font": {"desktop": {"value": {
                 "fontFamily": "{{design:font:body}}", "size": "16px",
                 "color": "{{design:color:parchment-700}}"}}}}},
               "decoration": {"spacing": {"desktop": {"value": {"padding": {"bottom": "24px"}}}}}},
              {"type": "divi/text",
               "content": "<h4>Horario</h4><p>Lunes a viernes: 9:00 - 18:00<br>S&aacute;bados: 10:00 - 14:00</p>",
               "headingFont": {"h4": {"font": {"desktop": {"value": {
                 "fontFamily": "{{design:font:ui}}", "size": "11px", "weight": "500",
                 "textTransform": "uppercase", "letterSpacing": "0.08em",
                 "color": "{{design:color:accent}}"}}}}},
               "bodyFont": {"body": {"font": {"desktop": {"value": {
                 "fontFamily": "{{design:font:body}}", "size": "16px",
                 "color": "{{design:color:parchment-700}}"}}}}}}
             ]}
          ]
        }
      ]
    }
  ]
}
