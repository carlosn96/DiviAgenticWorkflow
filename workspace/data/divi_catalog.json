    "blurb_icon_color": {
      "path": "imageIcon.advanced.color.desktop.value",
      "type": "color",
      "impact": "medium",
      "brand_tokens": ["accent", "premium", "text-on-dark"]
    },
    "image_border_radius": {
      "path": "decoration.border.desktop.value.radius",
      "type": "object",
      "impact": "medium"
    },
    "image_box_shadow": {
      "path": "decoration.boxShadow.desktop.value",
