  "combination_rules": {
    "glass_morphism": {
      "description": "Para crear glass effect, estas props deben ir juntas",
      "required": ["backdrop_filter", "bg_color", "border_width", "border_color"],
      "optional": ["box_shadow", "border_radius"],
      "backdrops": ["blur(8px)", "blur(12px)", "blur(16px)", "blur(24px)"],
      "bg_colors_with_alpha": ["glass-bg"],
      "min_alpha": 0.85
    },
    "glow_effect": {
      "description": "Para crear glow, estas props deben combinarse",
      "required": ["box_shadow_hover", "transform_hover"],
      "optional": ["text_shadow"],
      "glow_colors": ["glow-accent", "glow-accent-strong"],
      "shadow_props": {
        "blur": "24px-40px",
        "spread": "4px-8px",
        "position": "outer"
      }
    },
    "gradient_overlay": {
      "description": "Gradiente sobre fondo oscuro para profundidad",
      "required": ["bg_color", "overlay_gradient"],
      "bg_must_be_dark": true,
      "gradient_types": ["radial_glow_top_right", "radial_glow_center", "radial_glow_bottom_left"]
    },
    "card_elevated": {
      "description": "Card que se eleva en hover",
      "required": ["box_shadow_hover", "transform_hover"],
      "transform": {"translate_y": "-4px"},
      "shadow": {"vertical": "8px", "blur": "24px", "color_alpha": "0.12"}
    },
    "parallax_hero": {
      "description": "Hero con parallax vertical",
      "required": ["scroll_vertical_motion", "bg_color"],
      "motion": {"start": "6", "mid": "0", "end": "-4"},
      "trigger": "middle"
    },
    "staggered_entrance": {
      "description": "Animación escalonada para grids de items",
      "base_delay": "0ms",
      "step": "100ms",
      "max_delay": "400ms",
      "applies_to": ["features", "stats", "testimonials", "pricing"]
    },
    "shape_transition": {
      "description": "Transición suave entre secciones con shape divider",
      "required": ["shape_divider_top"],
      "or": ["shape_divider_bottom"],
      "recommended_styles": ["curve", "wave"],
      "color_matches_next_section_bg": true
    }
  },

  "strategy_adaptation": {
    "cool-luxury": {
      "preferred_blocks": ["hero_glass", "features_glass_grid", "stats_dark_counters", "testimonials_white_cards", "pricing_glass_tables", "cta_epic"],
      "avoid_blocks": ["features_light_grid"],
      "color_adjustments": {
        "glass_bg_alpha": 0.88,
        "glow_intensity": "medium",
        "shadow_alpha": 0.08
      },
      "typography_rules": {
        "display_font": "premium sans-serif",
        "letter_spacing_headline": "-0.5px",
        "line_height_hero": "1.1em"
