{
    "block": {
        "name": "divi/number-counter",
        "attrs": {
            "module": {
                "meta": {
                    "adminLabel": {
                        "desktop": {
                            "value": "Number Counter"
                        }
                    }
                },
                "advanced": {
                    "text": {
                        "text": {
                            "desktop": {
                                "value": {
                                    "color": "light",
                                    "orientation": "center"
                                }
                            }
                        }
                    }
                }
            },
            "title": {
                "decoration": {
                    "font": {
                        "font": {
                            "desktop": {
                                "value": {
                                    "headingLevel": "h3"
                                }
                            }
                        }
                    }
                }
            },
            "number": {
                "innerContent": {
                    "desktop": {
                        "value": "0"
                    }
                },
                "advanced": {
                    "enablePercentSign": {
                        "desktop": {
                            "value": "on"
                        }
                    }
                },
                "decoration": {
                    "font": {
                        "font": {
                            "desktop": {
                                "value": {
                                    "color": "$variable({\"type\":\"color\",\"value\":{\"name\":\"gcid-primary-color\",\"settings\":{}}})$"
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}