{
    "block": {
        "name": "divi/counters",
        "attrs": {
            "module": {
                "meta": {
                    "adminLabel": {
                        "desktop": {
                            "value": "Bar Counters"
                        }
                    }
                },
                "advanced": {
                    "html": {
                        "desktop": {
                            "value": {
                                "elementType": "ul"
                            }
                        }
                    },
                    "text": {
                        "text": {
                            "desktop": {
                                "value": {
                                    "color": "light"
                                }
                            }
                        }
                    }
                }
            },
            "barCounter": {},
            "title": {},
            "barProgress": {
                "advanced": {
                    "usePercentages": {
                        "desktop": {
                            "value": "on"
                        }
                    }
                }
            },
            "children": {
                "barProgress": {
                    "decoration": {
                        "background": {
                            "desktop": {
                                "value": {
                                    "color": "$variable({\"type\":\"color\",\"value\":{\"name\":\"gcid-primary-color\",\"settings\":{}}})$"
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}