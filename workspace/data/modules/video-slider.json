{
    "block": {
        "name": "divi/video-slider",
        "attrs": {
            "module": {
                "meta": {
                    "adminLabel": {
                        "desktop": {
                            "value": "Video Slider"
                        }
                    }
                }
            },
            "video": {},
            "overlay": {
                "advanced": {
                    "desktop": {
                        "value": {
                            "showImageOverlay": "off"
                        }
                    }
                },
                "decoration": {
                    "background": {
                        "desktop": {
                            "value": {
                                "color": "rgba(0,0,0,.6)"
                            }
                        }
                    }
                }
            },
            "playIcon": {
                "decoration": {
                    "icon": {
                        "desktop": {
                            "value": {
                                "size": "96px",
                                "useSize": "off"
                            }
                        }
                    }
                }
            },
            "sliderControls": {
                "advanced": {
                    "desktop": {
                        "value": {
                            "color": "light",
                            "useArrows": "on",
                            "useThumbnails": "on"
                        }
                    }
                }
            }
        }
    }
}