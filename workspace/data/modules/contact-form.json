{
    "block": {
        "name": "divi/contact-form",
        "attrs": {
            "module": {
                "meta": {
                    "adminLabel": {
                        "desktop": {
                            "value": "Contact Form"
                        }
                    }
                },
                "advanced": {
                    "spamProtection": {
                        "desktop": {
                            "value": {
                                "enabled": "off",
                                "useBasicCaptcha": "on"
                            }
                        }
                    }
                }
            },
            "title": {
                "decoration": {
                    "font": {
                        "font": {
                            "desktop": {
                                "value": {
                                    "headingLevel": "h1"
                                }
                            }
                        }
                    }
                }
            },
            "captcha": {},
            "field": {},
            "checkbox": {},
            "radio": {},
            "button": {
                "innerContent": {
                    "desktop": {
                        "value": {
                            "text": "Submit"
                        }
                    }
                },
                "decoration": {
                    "button": {
                        "desktop": {
                            "value": {
                                "icon": {
                                    "enable": "on"
                                }
                            }
                        }
                    },
                    "sizing": {
                        "desktop": {
                            "value": {
                                "alignment": "right"
                            }
                        }
                    }
                }
            },
            "email": {},
            "redirect": {
                "advanced": {
                    "useRedirect": {
                        "desktop": {
                            "value": "off"
                        }
                    }
                }
            }
        }
    }
}