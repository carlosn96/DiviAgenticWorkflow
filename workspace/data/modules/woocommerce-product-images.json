{
    "block": {
        "name": "divi/woocommerce-product-images",
        "attrs": {
            "module": {
                "meta": {
                    "adminLabel": {
                        "desktop": {
                            "value": "Woo Product Images"
                        }
                    }
                }
            },
            "image": {
                "advanced": {
                    "forceFullwidth": {
                        "desktop": {
                            "value": "off"
                        }
                    }
                }
            },
            "content": {
                "advanced": {
                    "product": {
                        "desktop": {
                            "value": "dynamic"
                        }
                    }
                }
            },
            "elements": {
                "advanced": {
                    "showProductGallery": {
                        "desktop": {
                            "value": "on"
                        }
                    },
                    "showProductImage": {
                        "desktop": {
                            "value": "on"
                        }
                    },
                    "showSaleBadge": {
                        "desktop": {
                            "value": "on"
                        }
                    }
                }
            },
            "saleBadge": {},
            "galleryGrid": {
                "decoration": {
                    "layout": {
                        "desktop": {
                            "value": {
                                "columnGap": "30px",
                                "display": "grid",
                                "gridColumnCount": "4",
                                "rowGap": "30px"
                            }
                        }
                    }
                }
            }
        }
    }
}