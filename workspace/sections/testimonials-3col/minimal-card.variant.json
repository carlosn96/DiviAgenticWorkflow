{
  "presets": ["section:white"],
  "decoration": {
    "spacing": {
      "desktop": { "value": { "padding": { "top": "120px", "bottom": "120px", "right": "96px", "left": "96px" } } },
      "tablet": { "value": { "padding": { "top": "80px", "bottom": "80px", "right": "48px", "left": "48px" } } },
      "phone": { "value": { "padding": { "top": "56px", "bottom": "56px", "right": "24px", "left": "24px" } } }
    },
    "scroll": {
      "desktop": { "value": "fade-in" }
    }
  },
  "rows": [
    {
      "column_structure": "1_1",
      "columns": [
        {
          "type": "1_1",
          "decoration": {
            "spacing": {
              "desktop": { "value": { "max_width": "700px", "align": "center", "padding": { "bottom": "64px" } } }
            }
          },
          "modules": [
            {
              "type": "divi/text",
              "presets": ["text:eyebrow"],
              "content": "<p>{{slot:eyebrow}}</p>"
            },
            {
              "type": "divi/heading",
              "presets": ["text:display-md"],
              "decoration": {
                "animation": {
                  "desktop": { "value": { "style": "fade", "direction": "bottom", "duration": "600ms", "delay": "100ms" } }
                }
              },
              "content": "<h2>{{slot:title}}</h2>"
            }
          ]
        }
      ]
    },
    {
      "column_structure": "1_3,1_3,1_3",
      "_repeat": {
        "source": "testimonials",
        "target": "columns",
        "column_type": "1_3"
      },
      "modules": [
        {
          "type": "divi/testimonial",
          "presets": ["module:card"],
          "decoration": {
            "border": {
              "desktop": {
                "value": {
                  "styles": "solid",
                  "color": "{{design:color:surface-light}}",
                  "width": "1px",
                  "radii": "{{design:radius:md}}"
                }
              }
            },
            "box_shadow": {
              "desktop": { "value": { "style": "none" } }
            },
            "animation": {
              "desktop": { "value": { "style": "fade", "duration": "500ms", "delay": "150ms" } }
            }
          },
          "content": "<p>{{slot:text}}</p>",
          "author": "{{slot:name}}",
          "jobTitle": "{{slot:role}}",
          "portrait": "{{slot:avatar}}"
        }
      ]
    }
  ]
}
