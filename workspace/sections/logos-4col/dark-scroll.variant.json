{
  "presets": ["section:dark"],
  "decoration": {
    "spacing": {
      "desktop": { "value": { "padding": { "top": "100px", "bottom": "100px", "right": "96px", "left": "96px" } } },
      "tablet": { "value": { "padding": { "top": "64px", "bottom": "64px", "right": "48px", "left": "48px" } } },
      "phone": { "value": { "padding": { "top": "48px", "bottom": "48px", "right": "24px", "left": "24px" } } }
    },
    "scroll": {
      "desktop": { "value": "fade-in" }
    }
  },
  "rows": [
    {
      "column_structure": "1_1",
      "columns": [
        {
          "type": "1_1",
          "decoration": {
            "spacing": {
              "desktop": { "value": { "align": "center", "padding": { "bottom": "48px" } } }
            }
          },
          "modules": [
            {
              "type": "divi/heading",
              "presets": ["text:display-md-light"],
              "decoration": {
                "animation": {
                  "desktop": { "value": { "style": "fade", "direction": "bottom", "duration": "600ms", "delay": "100ms" } }
                }
              },
              "content": "<h2>{{slot:title}}</h2>"
            },
            {
              "type": "divi/text",
              "presets": ["text:lead-dark"],
              "content": "<p>{{slot:text}}</p>"
            }
          ]
        }
      ]
    },
    {
      "column_structure": "1_4,1_4,1_4,1_4",
      "_repeat": {
        "source": "logos",
        "target": "columns",
        "column_type": "1_4"
      },
      "modules": [
        {
          "type": "divi/blurb",
          "presets": ["module:glass-card"],
          "decoration": {
            "animation": {
              "desktop": { "value": { "style": "fade", "duration": "500ms", "delay": "200ms" } }
            }
          },
          "title": "",
          "icon": "{{slot:icon}}",
          "content": "<p style='text-align: center; font-size: 0.85rem;'>{{slot:name}}</p>"
        }
      ]
    }
  ]
}
