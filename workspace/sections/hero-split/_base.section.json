{
  "presets": ["section:hero-dark"],
  "decoration": {
    "spacing": {
      "desktop": { "value": { "padding": { "top": "160px", "bottom": "120px", "right": "96px", "left": "96px" } } },
      "tablet": { "value": { "padding": { "top": "96px", "bottom": "80px", "right": "48px", "left": "48px" } } },
      "phone": { "value": { "padding": { "top": "64px", "bottom": "64px", "right": "24px", "left": "24px" } } }
    },
    "animation": {
      "desktop": { "value": { "style": "fade", "duration": "800ms", "delay": "0ms" } }
    }
  },
  "rows": [
    {
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "decoration": {
            "spacing": {
              "desktop": { "value": { "padding": { "right": "48px" } } },
              "tablet": { "value": { "padding": { "right": "0" } } }
            }
          },
          "modules": [
            {
              "type": "divi/text",
              "presets": ["text:eyebrow-dark"],
              "content": "<p>{{slot:eyebrow}}</p>"
            },
            {
              "type": "divi/heading",
              "presets": ["text:hero-title"],
              "content": "<h1>{{slot:title}}</h1>"
            },
            {
              "type": "divi/text",
              "presets": ["text:lead"],
              "decoration": {
                "spacing": {
                  "desktop": { "value": { "padding": { "bottom": "32px" } } }
                }
              },
              "content": "<p>{{slot:text}}</p>"
            },
            {
              "type": "divi/button",
              "presets": ["module:btn-primary"],
              "button_text": "{{slot:btn_primary_text}}",
              "button_url": "{{slot:btn_primary_url}}"
            },
            {
              "type": "divi/button",
              "presets": ["module:btn-ghost"],
              "button_text": "{{slot:btn_secondary_text}}",
              "button_url": "{{slot:btn_secondary_url}}"
            }
          ]
        },
        {
          "type": "1_2",
          "modules": [
            {
              "type": "divi/blurb",
              "presets": ["module:glass-card", "transform:hover-lift"],
              "title": "",
              "icon": "{{slot:decorative_icon}}",
              "content": "<p style='font-size: 1.5rem; line-height: 1.8; font-style: italic; color: var(--gcid-parchment-200); text-align: center; padding: 2rem;'>{{slot:decorative_text}}<br><span style='font-size: 0.9rem; color: var(--gcid-sepia-300);'>{{slot:decorative_attribution}}</span></p>"
            }
          ]
        }
      ]
    }
  ]
}
