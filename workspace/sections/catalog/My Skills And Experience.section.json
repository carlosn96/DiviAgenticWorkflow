{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "{{design:color:parchment-50}}",
          "image": {
            "url": "https://diviplus.io/wp-content/uploads/2019/11/dt-elements.png",
            "size": "cover",
            "position": "center center",
            "repeat": "no-repeat",
            "parallax": {
              "enabled": "off"
            }
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "4_4",
      "columns": [
        {
          "type": "4_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "0px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:text}}"
            },
            {
              "type": "divi/divider",
              "module": "divi/divider",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "0px"
                      }
                    }
                  }
                }
              },
              "show_divider": "on"
            }
          ]
        }
      ]
    }
  ]
}