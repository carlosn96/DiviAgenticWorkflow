{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "gradient": {
            "enabled": "on",
            "type": "linear",
            "direction": "130deg",
            "overlaysImage": "on",
            "stops": [
              {
                "color": "rgba(0,0,0,0.6)",
                "position": "0%"
              },
              {
                "color": "rgba(0,0,0,0)",
                "position": "100%"
              }
            ]
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "src": "{{slot:features[0].image}}",
              "alt": ""
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "content": "{{slot:features[0].title}}",
              "level": "h2"
            },
            {
              "type": "divi/icon-list",
              "module": "divi/icon-list",
              "decoration": {
                "background": {
                  "desktop": {
                    "value": {
                      "color": "{{design:color:parchment-50}}"
                    }
                  }
                },
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "40px",
                        "right": "20px",
                        "bottom": "40px",
                        "left": "20px"
                      }
                    }
                  }
                },
                "boxShadow": {
                  "desktop": {
                    "value": {
                      "style": "preset1",
                      "color": "rgba(26,24,20,0.06)"
                    }
                  }
                }
              },
              "children": [
                {
                  "type": "divi/icon-list-item",
                  "module": "divi/icon-list-item",
                  "content": ""
                },
                {
                  "type": "divi/icon-list-item",
                  "module": "divi/icon-list-item",
                  "content": ""
                },
                {
                  "type": "divi/icon-list-item",
                  "module": "divi/icon-list-item",
                  "content": ""
                },
                {
                  "type": "divi/icon-list-item",
                  "module": "divi/icon-list-item",
                  "content": ""
                },
                {
                  "type": "divi/icon-list-item",
                  "module": "divi/icon-list-item",
                  "content": ""
                },
                {
                  "type": "divi/icon-list-item",
                  "module": "divi/icon-list-item",
                  "content": ""
                },
                {
                  "type": "divi/icon-list-item",
                  "module": "divi/icon-list-item",
                  "content": ""
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}