{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "rgba(253,251,247,0.6)",
          "image": {
            "url": "https://diviplus.io/wp-content/uploads/2019/11/event.webp?_t=1736317448",
            "size": "cover",
            "position": "center center",
            "repeat": "no-repeat",
            "parallax": {
              "enabled": "off"
            }
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "background": {
          "desktop": {
            "value": {
              "color": "rgba(214,204,186,0.2)"
            }
          }
        },
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "top": "50px",
                "right": "30px",
                "bottom": "50px",
                "left": "30px"
              }
            }
          }
        },
        "border": {
          "desktop": {
            "value": {
              "radius": {
                "topLeft": "20px",
                "topRight": "20px",
                "bottomRight": "20px",
                "bottomLeft": "20px"
              }
            }
          }
        }
      },
      "column_structure": "1_3,1_3,1_3",
      "columns": [
        {
          "type": "1_3",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "decoration": {
                "background": {
                  "desktop": {
                    "value": {
                      "color": "rgba(214,204,186,0.3)"
                    }
                  }
                },
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "10px",
                        "right": "10px",
                        "bottom": "5px",
                        "left": "10px"
                      }
                    }
                  }
                },
                "border": {
                  "desktop": {
                    "value": {
                      "radius": {
                        "topLeft": "60px",
                        "topRight": "60px",
                        "bottomRight": "60px",
                        "bottomLeft": "60px"
                      }
                    }
                  }
                }
              },
              "title": "{{slot:features[0].title}}",
              "content": "",
              "src": ""
            },
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "content": "{{slot:features[0].title}}",
              "level": "h2"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:features[0].text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:ink}}"
                  }
                }
              }
            },
            {
              "type": "divi/button",
              "module": "divi/button",
              "button_text": "{{slot:features[0].btn_text}}",
              "button_url": "{{slot:features[0].btn_url}}"
            }
          ]
        },
        {
          "type": "1_3",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "src": "{{slot:features[1].image}}",
              "alt": ""
            }
          ]
        },
        {
          "type": "1_3",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "bottom": "10px"
                      }
                    }
                  }
                }
              },
              "title": "{{slot:features[2].title}}",
              "content": "<p>Personalized travel plans to suit your preferences and budget.</p>",
              "src": ""
            },
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "bottom": "10px"
                      }
                    }
                  }
                }
              },
              "title": "{{slot:features[2].title}}",
              "content": "<p>Expertly curated tours to explore iconic destinations.</p>",
              "src": ""
            },
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "title": "{{slot:features[2].title}}",
              "content": "<p>Dedicated support to ensure a smooth and stress-free journey.</p>",
              "src": ""
            }
          ]
        }
      ]
    }
  ]
}