{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "gradient": {
            "enabled": "on",
            "type": "circular",
            "direction": "180deg",
            "overlaysImage": "on",
            "stops": [
              {
                "color": "rgba(0,0,0,0.6)",
                "position": "0%"
              },
              {
                "color": "rgba(0,0,0,0)",
                "position": "100%"
              }
            ]
          }
        }
      }
    },
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "0px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "top": "0px",
                "left": "10%"
              }
            }
          }
        }
      },
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "content": "{{slot:title}}",
              "level": "h2"
            },
            {
              "type": "divi/divider",
              "module": "divi/divider",
              "show_divider": "on"
            }
          ]
        }
      ]
    }
  ]
}