{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "rgba(26,24,20,0.3)",
          "image": {
            "url": "https://diviplus.io/wp-content/uploads/2019/11/divi-plus-wedding-header-1.jpg",
            "size": "cover",
            "position": "center center",
            "repeat": "no-repeat",
            "parallax": {
              "enabled": "off"
            }
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "top": "12%",
                "right": "0%",
                "bottom": "12%",
                "left": "0%"
              }
            }
          }
        }
      },
      "column_structure": "4_4",
      "columns": [
        {
          "type": "4_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:eyebrow}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "rgba(253,251,247,0.8)",
                    "size": "28px"
                  }
                }
              }
            },
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "content": "{{slot:title}}",
              "level": "h2"
            },
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            }
          ]
        }
      ]
    }
  ]
}