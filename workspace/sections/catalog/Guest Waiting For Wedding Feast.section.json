{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "{{design:color:error}}"
        }
      }
    },
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "0px",
            "bottom": "0px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "top": "0px",
                "bottom": "0px"
              }
            }
          }
        }
      },
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "decoration": {
            "spacing": {
              "desktop": {
                "value": {
                  "padding": {
                    "top": "4%",
                    "right": "6%",
                    "bottom": "4%",
                    "left": "6%"
                  }
                }
              }
            }
          },
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:parchment-50}}",
                    "size": "40px"
                  }
                }
              }
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "20px",
                        "bottom": "20px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:parchment-50}}",
                    "size": "21px"
                  }
                }
              }
            },
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "40px",
                        "bottom": "40px"
                      }
                    }
                  }
                }
              }
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "20px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:parchment-50}}",
                    "size": "34px"
                  }
                }
              }
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "decoration": {
            "background": {
              "desktop": {
                "value": {
                  "image": {
                    "url": "https://diviplus.io/wp-content/uploads/2020/11/wedding-price-list-section-bg.jpg",
                    "size": "cover",
                    "position": "center center",
                    "repeat": "no-repeat",
                    "parallax": {
                      "enabled": "off"
                    }
                  }
                }
              }
            }
          },
          "modules": []
        }
      ]
    }
  ]
}