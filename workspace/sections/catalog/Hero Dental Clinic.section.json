{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "gradient": {
            "enabled": "on",
            "type": "radial",
            "direction": "180deg",
            "overlaysImage": "on",
            "stops": [
              {
                "color": "{{design:color:parchment-500}}",
                "position": "0%"
              },
              {
                "color": "rgba(61,107,79,0.0)",
                "position": "100%"
              }
            ]
          },
          "image": {
            "url": "https://diviplus.io/wp-content/uploads/2020/12/dental-header-bg.jpg",
            "size": "cover",
            "position": "top_center",
            "repeat": "no-repeat",
            "parallax": {
              "enabled": "off"
            }
          }
        }
      }
    },
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "100px",
            "bottom": "100px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "content": "{{slot:title}}",
              "level": "h2"
            },
            {
              "type": "divi/button",
              "module": "divi/button",
              "button_text": "{{slot:btn_primary_text}}",
              "button_url": "{{slot:btn_primary_url}}"
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": []
        }
      ]
    }
  ]
}