{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "{{design:color:parchment-100}}"
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/row-inner",
              "module": "divi/row-inner",
              "column_structure": "4_4",
              "columns": [
                {
                  "type": "4_4",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/heading",
                      "module": "divi/heading",
                      "decoration": {
                        "spacing": {
                          "desktop": {
                            "value": {
                              "margin": {
                                "bottom": "10px"
                              }
                            }
                          }
                        }
                      },
                      "content": "{{slot:title}}",
                      "level": "h2"
                    },
                    {
                      "type": "divi/text",
                      "module": "divi/text",
                      "content": "{{slot:text}}",
                      "bodyFont": {
                        "desktop": {
                          "value": {
                            "fontFamily": "{{design:font:body}}",
                            "color": "{{design:color:ink}}"
                          }
                        }
                      }
                    }
                  ]
                }
              ]
            },
            {
              "type": "divi/row-inner",
              "module": "divi/row-inner",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "0px",
                        "bottom": "10px"
                      }
                    }
                  }
                }
              },
              "column_structure": "1_3,1_3,1_3",
              "columns": [
                {
                  "type": "1_3",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/placeholder",
                      "module": "divi/placeholder",
                      "decoration": {
                        "background": {
                          "desktop": {
                            "value": {
                              "color": "{{design:color:parchment-50}}"
                            }
                          }
                        },
                        "spacing": {
                          "desktop": {
                            "value": {
                              "padding": {
                                "top": "20px",
                                "right": "20px",
                                "bottom": "20px",
                                "left": "20px"
                              }
                            }
                          }
                        },
                        "border": {
                          "desktop": {
                            "value": {
                              "radius": {
                                "topLeft": "3px",
                                "topRight": "3px",
                                "bottomRight": "3px",
                                "bottomLeft": "3px"
                              }
                            }
                          }
                        }
                      }
                    }
                  ]
                },
                {
                  "type": "1_3",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/placeholder",
                      "module": "divi/placeholder",
                      "decoration": {
                        "background": {
                          "desktop": {
                            "value": {
                              "color": "{{design:color:parchment-50}}"
                            }
                          }
                        },
                        "spacing": {
                          "desktop": {
                            "value": {
                              "padding": {
                                "top": "20px",
                                "right": "20px",
                                "bottom": "20px",
                                "left": "20px"
                              }
                            }
                          }
                        },
                        "border": {
                          "desktop": {
                            "value": {
                              "radius": {
                                "topLeft": "3px",
                                "topRight": "3px",
                                "bottomRight": "3px",
                                "bottomLeft": "3px"
                              }
                            }
                          }
                        }
                      }
                    }
                  ]
                },
                {
                  "type": "1_3",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/placeholder",
                      "module": "divi/placeholder",
                      "decoration": {
                        "background": {
                          "desktop": {
                            "value": {
                              "color": "{{design:color:parchment-50}}"
                            }
                          }
                        },
                        "spacing": {
                          "desktop": {
                            "value": {
                              "padding": {
                                "top": "20px",
                                "right": "20px",
                                "bottom": "20px",
                                "left": "20px"
                              }
                            }
                          }
                        },
                        "border": {
                          "desktop": {
                            "value": {
                              "radius": {
                                "topLeft": "3px",
                                "topRight": "3px",
                                "bottomRight": "3px",
                                "bottomLeft": "3px"
                              }
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              ]
            },
            {
              "type": "divi/row-inner",
              "module": "divi/row-inner",
              "column_structure": "4_4",
              "columns": [
                {
                  "type": "4_4",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/button",
                      "module": "divi/button",
                      "button_text": "{{slot:btn_primary_text}}",
                      "button_url": "{{slot:btn_primary_url}}"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "src": "{{slot:stats[1].image}}",
              "alt": ""
            }
          ]
        }
      ]
    }
  ]
}