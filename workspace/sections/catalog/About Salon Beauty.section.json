{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "rgba(253,251,247,0.0)"
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/row-inner",
              "module": "divi/row-inner",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "bottom": "30px"
                      }
                    }
                  }
                }
              },
              "column_structure": "4_4",
              "columns": [
                {
                  "type": "4_4",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/heading",
                      "module": "divi/heading",
                      "content": "{{slot:title}}",
                      "level": "h2"
                    },
                    {
                      "type": "divi/heading",
                      "module": "divi/heading",
                      "content": "{{slot:title}}",
                      "level": "h2"
                    },
                    {
                      "type": "divi/text",
                      "module": "divi/text",
                      "content": "{{slot:text}}",
                      "bodyFont": {
                        "desktop": {
                          "value": {
                            "fontFamily": "{{design:font:body}}",
                            "size": "18px"
                          }
                        }
                      }
                    }
                  ]
                }
              ]
            },
            {
              "type": "divi/row-inner",
              "module": "divi/row-inner",
              "column_structure": "1_3,1_3,1_3",
              "columns": [
                {
                  "type": "1_3",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/placeholder",
                      "module": "divi/placeholder",
                      "decoration": {
                        "background": {
                          "desktop": {
                            "value": {
                              "color": "{{design:color:ink}}"
                            }
                          }
                        },
                        "spacing": {
                          "desktop": {
                            "value": {
                              "padding": {
                                "top": "10px",
                                "bottom": "10px"
                              }
                            }
                          }
                        },
                        "border": {
                          "desktop": {
                            "value": {
                              "radius": {
                                "topLeft": "5px",
                                "topRight": "5px",
                                "bottomRight": "5px",
                                "bottomLeft": "5px"
                              }
                            }
                          }
                        },
                        "boxShadow": {
                          "desktop": {
                            "value": {
                              "style": "preset3",
                              "color": "rgba(26,24,20,0.08)"
                            }
                          }
                        }
                      }
                    }
                  ]
                },
                {
                  "type": "1_3",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/placeholder",
                      "module": "divi/placeholder",
                      "decoration": {
                        "background": {
                          "desktop": {
                            "value": {
                              "color": "{{design:color:parchment-300}}"
                            }
                          }
                        },
                        "spacing": {
                          "desktop": {
                            "value": {
                              "padding": {
                                "top": "10px",
                                "bottom": "10px"
                              }
                            }
                          }
                        },
                        "border": {
                          "desktop": {
                            "value": {
                              "radius": {
                                "topLeft": "5px",
                                "topRight": "5px",
                                "bottomRight": "5px",
                                "bottomLeft": "5px"
                              }
                            }
                          }
                        },
                        "boxShadow": {
                          "desktop": {
                            "value": {
                              "style": "preset3",
                              "color": "rgba(26,24,20,0.08)"
                            }
                          }
                        }
                      }
                    }
                  ]
                },
                {
                  "type": "1_3",
                  "module": "divi/column-inner",
                  "modules": []
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}