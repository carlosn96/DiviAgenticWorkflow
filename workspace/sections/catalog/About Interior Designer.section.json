{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "image": {
            "url": "https://diviplus.io/wp-content/uploads/2019/11/interior-designer-about-section-bg.png",
            "size": "cover",
            "position": "center center",
            "repeat": "no-repeat",
            "parallax": {
              "enabled": "off"
            }
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "2_5,3_5",
      "columns": [
        {
          "type": "2_5",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "bottom": "20px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:title}}",
              "level": "h2"
            },
            {
              "type": "divi/image",
              "module": "divi/image",
              "src": "https://themes.diviplus.io/interior-designer/wp-content/uploads/2022/10/about-girl.webp",
              "alt": ""
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "background": {
                  "desktop": {
                    "value": {
                      "color": "{{design:color:premium}}"
                    }
                  }
                },
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "30px",
                        "right": "30px",
                        "bottom": "30px",
                        "left": "30px"
                      }
                    }
                  }
                },
                "border": {
                  "desktop": {
                    "value": {
                      "radius": {
                        "topLeft": "80%",
                        "topRight": "80%",
                        "bottomRight": "80%",
                        "bottomLeft": "80%"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "size": "18px"
                  }
                }
              }
            }
          ]
        },
        {
          "type": "3_5",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}"
            },
            {
              "type": "divi/button",
              "module": "divi/button",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "0px",
                        "bottom": "0px"
                      }
                    }
                  }
                }
              },
              "button_text": "{{slot:btn_primary_text}}",
              "button_url": "{{slot:btn_primary_url}}"
            },
            {
              "type": "divi/image",
              "module": "divi/image",
              "src": "https://themes.diviplus.io/interior-designer/wp-content/uploads/2022/10/blog-01.webp",
              "alt": ""
            },
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            }
          ]
        }
      ]
    }
  ]
}