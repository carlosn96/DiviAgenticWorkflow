{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "{{design:color:parchment-100}}"
        }
      }
    },
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "100px",
            "bottom": "80px"
          }
        }
      }
    },
    "border": {
      "desktop": {
        "value": {
          "radius": {
            "topLeft": "5px",
            "topRight": "5px",
            "bottomRight": "5px",
            "bottomLeft": "5px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "top": "0px",
                "bottom": "0px"
              }
            }
          }
        }
      },
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "content": "{{slot:title}}",
              "level": "h2"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}"
            },
            {
              "type": "divi/button",
              "module": "divi/button",
              "button_text": "{{slot:btn_primary_text}}",
              "button_url": "{{slot:btn_primary_url}}"
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "src": "https://themes.diviplus.io/wedding-planner/wp-content/uploads/2021/11/dp-wedding-planner02.webp",
              "alt": ""
            },
            {
              "type": "divi/image",
              "module": "divi/image",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "top": "-30%"
                      }
                    }
                  }
                },
                "layout": {
                  "desktop": {
                    "value": {
                      "textAlign": "center"
                    }
                  }
                }
              },
              "src": "https://themes.diviplus.io/wedding-planner/wp-content/uploads/2021/11/dp-wedding-planner05.webp",
              "alt": ""
            },
            {
              "type": "divi/image",
              "module": "divi/image",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "-1px"
                      }
                    }
                  }
                }
              },
              "src": "https://themes.diviplus.io/wedding-planner/wp-content/uploads/2021/11/dp-wedding-planner02.webp",
              "alt": ""
            }
          ]
        }
      ]
    }
  ]
}