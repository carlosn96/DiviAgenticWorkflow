{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "rgba(253,251,247,0.0)",
          "gradient": {
            "enabled": "on",
            "type": "linear",
            "direction": "90deg",
            "overlaysImage": "on",
            "stops": [
              {
                "color": "{{design:color:parchment-100}}",
                "position": "0%"
              },
              {
                "color": "{{design:color:sepia-100}}",
                "position": "100%"
              }
            ]
          }
        }
      }
    },
    "boxShadow": {
      "desktop": {
        "value": {
          "style": "preset7",
          "color": "{{design:color:parchment-100}}"
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": []
        }
      ]
    }
  ]
}