{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "0px",
            "bottom": "0px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "top": "0px",
                "bottom": "0px"
              }
            }
          }
        }
      },
      "column_structure": "3_5,2_5",
      "columns": [
        {
          "type": "3_5",
          "module": "divi/column",
          "decoration": {
            "spacing": {
              "desktop": {
                "value": {
                  "padding": {
                    "top": "4%",
                    "right": "7%",
                    "bottom": "4%",
                    "left": "7%"
                  }
                }
              }
            }
          },
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "5px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:eyebrow}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:ink}}"
                  }
                }
              }
            },
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "background": {
                  "desktop": {
                    "value": {
                      "color": "rgba(0,0,0,0)"
                    }
                  }
                }
              }
            }
          ]
        },
        {
          "type": "2_5",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "src": "https://diviplus.io/wp-content/uploads/2020/09/pexels-negative-space-33999.jpg",
              "alt": ""
            }
          ]
        }
      ]
    }
  ]
}