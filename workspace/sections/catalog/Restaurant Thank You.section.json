{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "bottom": "0px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "4_4",
      "columns": [
        {
          "type": "4_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "content": "{{slot:title}}",
              "level": "h2"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}"
            },
            {
              "type": "divi/button",
              "module": "divi/button",
              "button_text": "{{slot:btn_primary_text}}",
              "button_url": "{{slot:btn_primary_url}}"
            }
          ]
        }
      ]
    },
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "background": {
          "desktop": {
            "value": {
              "color": "{{design:color:parchment-500}}"
            }
          }
        },
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "top": "70px",
                "right": "10%",
                "bottom": "70px",
                "left": "10%"
              },
              "margin": {
                "top": "50px"
              }
            }
          }
        }
      },
      "column_structure": "1_4,1_4,1_4,1_4",
      "columns": [
        {
          "type": "1_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "title": "{{slot:gallery[0].title}}",
              "content": "<p>+000-000-0000<br />+000-000-0000</p>",
              "src": ""
            }
          ]
        },
        {
          "type": "1_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "title": "{{slot:gallery[1].title}}",
              "content": "<p>abc@example.com<br />xyz@example.com</p>",
              "src": ""
            }
          ]
        },
        {
          "type": "1_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "title": "{{slot:gallery[2].title}}",
              "content": "<p>Plot Number 012, Street, City, State, Country 01234</p>",
              "src": ""
            }
          ]
        },
        {
          "type": "1_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "title": "{{slot:gallery[3].title}}",
              "content": "<p>+000-000-0000<br />+000-000-0000</p>",
              "src": ""
            }
          ]
        }
      ]
    }
  ]
}