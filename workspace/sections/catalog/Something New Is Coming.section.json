{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "{{design:color:parchment-100}}"
        }
      }
    },
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "10px",
            "bottom": "10px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "2_5,3_5",
      "columns": [
        {
          "type": "2_5",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "src": "",
              "alt": ""
            }
          ]
        },
        {
          "type": "3_5",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "content": "{{slot:title}}",
              "level": "h2"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:ink}}"
                  }
                }
              }
            },
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "30px",
                        "bottom": "30px"
                      }
                    }
                  }
                }
              }
            },
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            }
          ]
        }
      ]
    }
  ]
}