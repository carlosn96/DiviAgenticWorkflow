{
  "type": "regular",
  "module": "divi/section",
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:ink}}",
                    "size": "18px"
                  }
                }
              }
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "background": {
                  "desktop": {
                    "value": {
                      "gradient": {
                        "enabled": "on",
                        "type": "linear",
                        "direction": "180deg",
                        "overlaysImage": "on",
                        "stops": [
                          {
                            "color": "rgba(0,0,0,0.6)",
                            "position": "0%"
                          },
                          {
                            "color": "rgba(0,0,0,0)",
                            "position": "100%"
                          }
                        ]
                      }
                    }
                  }
                },
                "border": {
                  "desktop": {
                    "value": {
                      "radius": {
                        "topLeft": "4px",
                        "topRight": "4px",
                        "bottomRight": "4px",
                        "bottomLeft": "4px"
                      }
                    }
                  }
                },
                "boxShadow": {
                  "desktop": {
                    "value": {
                      "style": "preset1",
                      "color": "rgba(26,24,20,0.2)"
                    }
                  }
                }
              }
            }
          ]
        }
      ]
    }
  ]
}