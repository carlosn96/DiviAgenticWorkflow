{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "0px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "background": {
          "desktop": {
            "value": {
              "color": "{{design:color:parchment-300}}"
            }
          }
        },
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "top": "60px",
                "right": "10%",
                "bottom": "0px",
                "left": "10%"
              }
            }
          }
        }
      },
      "column_structure": "4_4",
      "columns": [
        {
          "type": "4_4",
          "module": "divi/column",
          "modules": []
        }
      ]
    },
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "4_4",
      "columns": [
        {
          "type": "4_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "-180px"
                      }
                    }
                  }
                }
              },
              "src": "",
              "alt": ""
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}"
            },
            {
              "type": "divi/divider",
              "module": "divi/divider",
              "show_divider": "on"
            }
          ]
        }
      ]
    }
  ]
}