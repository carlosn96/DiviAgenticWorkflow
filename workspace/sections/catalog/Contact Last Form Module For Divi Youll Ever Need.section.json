{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "gradient": {
            "enabled": "on",
            "type": "linear",
            "direction": "228deg",
            "overlaysImage": "on",
            "stops": [
              {
                "color": "rgba(61,107,79,0.6)",
                "position": "0%"
              },
              {
                "color": "rgba(61,107,79,0.38)",
                "position": "100%"
              }
            ]
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "4_4",
      "columns": [
        {
          "type": "4_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "5px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:ink}}"
                  }
                }
              }
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}"
            }
          ]
        }
      ]
    },
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "decoration": {
            "background": {
              "desktop": {
                "value": {
                  "gradient": {
                    "enabled": "on",
                    "type": "linear",
                    "direction": "180deg",
                    "overlaysImage": "on",
                    "stops": [
                      {
                        "color": "rgba(253,251,247,0.72)",
                        "position": "0%"
                      },
                      {
                        "color": "rgba(253,251,247,0.72)",
                        "position": "100%"
                      }
                    ]
                  },
                  "image": {
                    "url": "https://diviplus.io/wp-content/uploads/2020/09/wing-fly-aircraft-line-paper-circle-701998-pxhere.com_.jpg",
                    "size": "cover",
                    "position": "center center",
                    "repeat": "no-repeat",
                    "parallax": {
                      "enabled": "off"
                    }
                  }
                }
              }
            },
            "spacing": {
              "desktop": {
                "value": {
                  "padding": {
                    "top": "4%",
                    "right": "4%",
                    "bottom": "4%",
                    "left": "4%"
                  }
                }
              }
            }
          },
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "bottom": "30px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:text}}"
            },
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "30px",
                        "bottom": "30px"
                      }
                    }
                  }
                }
              },
              "title": "hello@example.com",
              "content": "",
              "src": ""
            },
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "30px",
                        "bottom": "30px"
                      }
                    }
                  }
                }
              },
              "title": "0123456789",
              "content": "",
              "src": ""
            },
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "30px",
                        "bottom": "30px"
                      }
                    }
                  }
                }
              },
              "title": "Address",
              "content": "890 Lorem Ipsum Street #12\nAlabama, United States",
              "src": ""
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "decoration": {
            "background": {
              "desktop": {
                "value": {
                  "color": "{{design:color:success}}"
                }
              }
            },
            "spacing": {
              "desktop": {
                "value": {
                  "padding": {
                    "top": "4%",
                    "right": "7%",
                    "bottom": "4%",
                    "left": "7%"
                  }
                }
              }
            }
          },
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "1px"
                      }
                    }
                  }
                }
              }
            }
          ]
        }
      ]
    }
  ]
}