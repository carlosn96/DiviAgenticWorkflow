{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "150px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "decoration": {
                "layout": {
                  "desktop": {
                    "value": {
                      "textAlign": "center"
                    }
                  }
                }
              },
              "src": "https://themes.diviplus.io/ngo/wp-content/uploads/2024/01/dpn-story.webp",
              "alt": ""
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/row-inner",
              "module": "divi/row-inner",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "bottom": "0px"
                      }
                    }
                  }
                }
              },
              "column_structure": "4_4",
              "columns": [
                {
                  "type": "4_4",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/text",
                      "module": "divi/text",
                      "decoration": {
                        "spacing": {
                          "desktop": {
                            "value": {
                              "margin": {
                                "bottom": "10px"
                              }
                            }
                          }
                        }
                      },
                      "content": "{{slot:text}}",
                      "bodyFont": {
                        "desktop": {
                          "value": {
                            "fontFamily": "{{design:font:body}}",
                            "color": "rgba(74,53,21,0.67)"
                          }
                        }
                      }
                    },
                    {
                      "type": "divi/heading",
                      "module": "divi/heading",
                      "content": "{{slot:title}}",
                      "level": "h2"
                    },
                    {
                      "type": "divi/text",
                      "module": "divi/text",
                      "content": "{{slot:text}}"
                    }
                  ]
                }
              ]
            },
            {
              "type": "divi/row-inner",
              "module": "divi/row-inner",
              "column_structure": "1_2,1_2",
              "columns": [
                {
                  "type": "1_2",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/blurb",
                      "module": "divi/blurb",
                      "title": "Our Mission",
                      "content": "<p>You can also style every aspect of this content in the module Design settings.</p>",
                      "src": ""
                    }
                  ]
                },
                {
                  "type": "1_2",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/blurb",
                      "module": "divi/blurb",
                      "title": "Our Vision",
                      "content": "<p>You can also style every aspect of this content in the module Design settings.</p>",
                      "src": ""
                    }
                  ]
                }
              ]
            },
            {
              "type": "divi/row-inner",
              "module": "divi/row-inner",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "0px",
                        "bottom": "0px"
                      }
                    }
                  }
                }
              },
              "column_structure": "4_4",
              "columns": [
                {
                  "type": "4_4",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/button",
                      "module": "divi/button",
                      "button_text": "{{slot:btn_primary_text}}",
                      "button_url": "{{slot:btn_primary_url}}"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}