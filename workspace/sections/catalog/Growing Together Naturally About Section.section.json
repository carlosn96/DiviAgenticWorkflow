{
  "type": "regular",
  "module": "divi/section",
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "decoration": {
                "background": {
                  "desktop": {
                    "value": {
                      "color": "{{design:color:accent-hover}}"
                    }
                  }
                },
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "15px",
                        "right": "15px",
                        "bottom": "15px",
                        "left": "15px"
                      }
                    }
                  }
                },
                "border": {
                  "desktop": {
                    "value": {
                      "radius": {
                        "topLeft": "100px",
                        "topRight": "100px",
                        "bottomRight": "100px",
                        "bottomLeft": "100px"
                      }
                    }
                  }
                }
              },
              "title": "15+",
              "content": "<p>Years of Experience</p>",
              "src": ""
            },
            {
              "type": "divi/image",
              "module": "divi/image",
              "src": "",
              "alt": ""
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "20px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:text}}"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "30px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:ink}}"
                  }
                }
              }
            },
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "title": "Passion for Plants",
              "content": "<p>We are dedicated to helping you create vibrant, thriving spaces with the perfect plants for every corner of your home or office.</p>",
              "src": ""
            },
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "title": "Expert Guidance",
              "content": "<p>Whether you're a seasoned gardener or just starting, we provide the tips and care advice you need to nurture your plants.</p>",
              "src": ""
            }
          ]
        }
      ]
    }
  ]
}