{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "8%",
            "bottom": "6%"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "3_4,1_4",
      "columns": [
        {
          "type": "3_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/row-inner",
              "module": "divi/row-inner",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "0px",
                        "bottom": "0px"
                      }
                    }
                  }
                }
              },
              "column_structure": "1_2,1_2",
              "columns": [
                {
                  "type": "1_2",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/image",
                      "module": "divi/image",
                      "src": "",
                      "alt": ""
                    }
                  ]
                },
                {
                  "type": "1_2",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/text",
                      "module": "divi/text",
                      "decoration": {
                        "spacing": {
                          "desktop": {
                            "value": {
                              "margin": {
                                "bottom": "10px"
                              }
                            }
                          }
                        }
                      },
                      "content": "{{slot:text}}"
                    },
                    {
                      "type": "divi/text",
                      "module": "divi/text",
                      "decoration": {
                        "spacing": {
                          "desktop": {
                            "value": {
                              "margin": {
                                "bottom": "50px"
                              }
                            }
                          }
                        }
                      },
                      "content": "{{slot:text}}"
                    },
                    {
                      "type": "divi/button",
                      "module": "divi/button",
                      "button_text": "{{slot:btn_primary_text}}",
                      "button_url": "{{slot:btn_primary_url}}"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "1_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "0px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:eyebrow}}"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "50px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:parchment-50}}"
                  }
                }
              }
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "0px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:eyebrow}}"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "50px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:parchment-50}}"
                  }
                }
              }
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "0px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:eyebrow}}"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:parchment-50}}"
                  }
                }
              }
            }
          ]
        }
      ]
    }
  ]
}