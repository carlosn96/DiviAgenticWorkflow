{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "{{design:color:parchment-50}}"
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "4_4",
      "columns": [
        {
          "type": "4_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "content": "{{slot:title}}",
              "level": "h2"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}"
            }
          ]
        }
      ]
    },
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "4_4",
      "columns": [
        {
          "type": "4_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "border": {
                  "desktop": {
                    "value": {
                      "radius": {
                        "topLeft": "5px",
                        "topRight": "5px",
                        "bottomRight": "5px",
                        "bottomLeft": "5px"
                      }
                    }
                  }
                },
                "boxShadow": {
                  "desktop": {
                    "value": {
                      "style": "preset2",
                      "color": "rgba(26,24,20,0.05)"
                    }
                  }
                }
              }
            }
          ]
        }
      ]
    },
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_4,1_4,1_4,1_4",
      "columns": [
        {
          "type": "1_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "10px",
                        "right": "10px",
                        "bottom": "10px",
                        "left": "10px"
                      }
                    }
                  }
                }
              },
              "title": "{{slot:features[0].title}}",
