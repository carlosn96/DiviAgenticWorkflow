{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "rgba(26,24,20,0.87)",
          "image": {
            "url": "https://diviplus.io/wp-content/uploads/2019/11/divi-plus-dual-button-digital.jpg",
            "size": "cover",
            "position": "center center",
            "repeat": "no-repeat",
            "parallax": {
              "enabled": "off"
            }
          }
        }
      }
    },
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "10%",
            "bottom": "10%"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "0px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:text}}"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "bottom": "28px"
                      },
                      "margin": {
                        "bottom": "12px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:text}}"
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/button",
              "module": "divi/button",
              "button_text": "{{slot:btn_primary_text}}",
              "button_url": "{{slot:btn_primary_url}}"
            }
          ]
        }
      ]
    }
  ]
}