{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "{{design:color:ink}}"
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "4_4",
      "columns": [
        {
          "type": "4_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "content": "{{slot:title}}",
              "level": "h2"
            }
          ]
        }
      ]
    },
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_3,1_3,1_3",
      "columns": [
        {
          "type": "1_3",
          "module": "divi/column",
          "decoration": {
            "background": {
              "desktop": {
                "value": {
                  "image": {
                    "url": "https://diviplus.io/wp-content/uploads/2025/06/gradient-color-bg.webp?_t=1749805925",
                    "size": "cover",
                    "position": "center center",
                    "repeat": "no-repeat",
                    "parallax": {
                      "enabled": "off"
                    }
                  }
                }
              }
            },
            "spacing": {
              "desktop": {
                "value": {
                  "padding": {
                    "top": "60px",
                    "right": "30px",
                    "bottom": "60px",
                    "left": "30px"
                  }
                }
              }
            },
            "border": {
              "desktop": {
                "value": {
                  "radius": {
                    "topLeft": "10px",
                    "topRight": "10px",
                    "bottomRight": "10px",
                    "bottomLeft": "10px"
                  }
                }
              }
            }
          },
          "modules": [
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "10px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:title}}",
              "level": "h2"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "25px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:parchment-50}}",
                    "size": "18px"
                  }
                }
              }
            },
            {
              "type": "divi/button",
              "module": "divi/button",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "0px"
                      }
                    }
                  }
                }
              },
              "button_text": "{{slot:btn_primary_text}}",
              "button_url": "{{slot:btn_primary_url}}"
