{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "rgba(166,124,64,0.1)"
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
