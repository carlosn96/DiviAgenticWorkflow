{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "30px",
            "bottom": "20px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            },
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            },
            {
              "type": "divi/image",
              "module": "divi/image",
              "src": "",
              "alt": ""
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/row-inner",
              "module": "divi/row-inner",
              "column_structure": "4_4",
              "columns": [
                {
                  "type": "4_4",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/text",
                      "module": "divi/text",
                      "decoration": {
                        "background": {
                          "desktop": {
                            "value": {
                              "color": "{{design:color:parchment-100}}"
                            }
                          }
                        },
                        "spacing": {
                          "desktop": {
                            "value": {
                              "margin": {
                                "bottom": "10px"
                              }
                            }
                          }
                        },
                        "border": {
                          "desktop": {
                            "value": {
                              "radius": {
                                "topLeft": "50px",
                                "topRight": "50px",
                                "bottomRight": "50px",
                                "bottomLeft": "50px"
                              }
                            }
                          }
                        }
                      },
                      "content": "{{slot:eyebrow}}",
                      "bodyFont": {
                        "desktop": {
                          "value": {
                            "fontFamily": "{{design:font:body}}",
                            "color": "{{design:color:premium}}"
                          }
                        }
                      }
                    },
                    {
                      "type": "divi/text",
                      "module": "divi/text",
                      "decoration": {
                        "spacing": {
                          "desktop": {
                            "value": {
                              "margin": {
                                "bottom": "10px"
                              }
                            }
                          }
                        }
                      },
                      "content": "{{slot:text}}"
                    },
                    {
                      "type": "divi/text",
                      "module": "divi/text",
                      "content": "{{slot:text}}"
                    }
                  ]
                }
              ]
            },
            {
              "type": "divi/row-inner",
              "module": "divi/row-inner",
              "column_structure": "1_2,1_2",
              "columns": [
                {
                  "type": "1_2",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/blurb",
                      "module": "divi/blurb",
                      "title": "Remote Tech Support",
                      "content": "",
                      "src": ""
                    }
                  ]
                },
                {
                  "type": "1_2",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/blurb",
                      "module": "divi/blurb",
                      "title": "Informed Consultation",
                      "content": "",
                      "src": ""
                    }
                  ]
                }
              ]
            },
            {
              "type": "divi/row-inner",
              "module": "divi/row-inner",
              "column_structure": "1_2,1_2",
              "columns": [
                {
                  "type": "1_2",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/button",
                      "module": "divi/button",
                      "button_text": "{{slot:btn_primary_text}}",
                      "button_url": "{{slot:btn_primary_url}}"
                    }
                  ]
                },
                {
                  "type": "1_2",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/blurb",
                      "module": "divi/blurb",
                      "title": "Talk to a Specialist",
                      "content": "<p><a href=\"+000-000-000\">+000-000-000</a></p>",
                      "src": ""
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
