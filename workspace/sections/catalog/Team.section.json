{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "rgba(253,251,247,0.9)",
          "image": {
            "url": "https://diviplus.io/wp-content/uploads/2019/11/dp-wedding10.webp",
            "size": "cover",
            "position": "bottom_center",
            "repeat": "no-repeat",
            "parallax": {
              "enabled": "off"
            }
          }
        }
      }
    },
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "180px",
            "bottom": "180px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:team[0].text}}"
            },
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:team[1].text}}"
            },
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            }
          ]
        }
      ]
    }
  ]
}