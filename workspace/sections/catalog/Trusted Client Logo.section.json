{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "{{design:color:ink}}"
        }
      }
    },
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "80px",
            "bottom": "80px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "background": {
          "desktop": {
            "value": {
              "color": "{{design:color:ink}}"
            }
          }
        },
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "top": "40px",
                "right": "30px",
                "bottom": "40px",
                "left": "30px"
              }
            }
          }
        },
        "border": {
          "desktop": {
            "value": {
              "radius": {
                "topLeft": "10px",
                "topRight": "10px",
                "bottomRight": "10px",
                "bottomLeft": "10px"
              }
            }
          }
        }
      },
      "column_structure": "1_4,3_4",
      "columns": [
        {
          "type": "1_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "content": "{{slot:title}}",
              "level": "h2"
            }
          ]
        },
        {
          "type": "3_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "0px",
                        "bottom": "0px"
                      }
                    }
                  }
                }
              }
            }
          ]
        }
      ]
    }
  ]
}