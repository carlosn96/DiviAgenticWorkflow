{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "{{design:color:ink}}",
          "gradient": {
            "enabled": "on",
            "type": "elliptical",
            "direction": "180deg",
            "overlaysImage": "on",
            "stops": [
              {
                "color": "rgba(0,0,0,0.6)",
                "position": "0%"
              },
              {
                "color": "rgba(0,0,0,0)",
                "position": "100%"
              }
            ]
          },
          "image": {
            "url": "https://diviplus.io/wp-content/uploads/2019/11/online-banking.webp",
            "size": "cover",
            "position": "center center",
            "repeat": "no-repeat",
            "parallax": {
              "enabled": "off"
            }
          }
        }
      }
    },
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "100px",
            "bottom": "150px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "bottom": "0px"
              }
            }
          }
        }
      },
      "column_structure": "4_4",
      "columns": [
        {
          "type": "4_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "10px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:text}}"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:parchment-50}}"
                  }
                }
              }
            }
          ]
        }
      ]
    },
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "4_4",
      "columns": [
        {
          "type": "4_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:parchment-50}}"
                  }
                }
              }
            }
          ]
        }
      ]
    },
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "top": "100px",
                "bottom": "20px"
              }
            }
          }
        }
      },
      "column_structure": "4_4",
      "columns": [
        {
          "type": "4_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}"
            }
          ]
        }
      ]
    },
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "top": "0px"
              }
            }
          }
        }
      },
      "column_structure": "1_6,1_6,1_6,1_6,1_6,1_6",
      "columns": [
        {
          "type": "1_6",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "src": "https://diviplus.io/wp-content/uploads/2019/11/logo-06-1.png",
              "alt": ""
            }
          ]
        },
        {
          "type": "1_6",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "src": "https://diviplus.io/wp-content/uploads/2019/11/logo-05-2.png",
              "alt": ""
            }
          ]
        },
        {
          "type": "1_6",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "src": "https://diviplus.io/wp-content/uploads/2019/11/logo-04-2.png",
              "alt": ""
            }
          ]
        },
        {
          "type": "1_6",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "src": "https://diviplus.io/wp-content/uploads/2019/11/logo-03-2.png",
              "alt": ""
            }
          ]
        },
        {
          "type": "1_6",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "src": "https://diviplus.io/wp-content/uploads/2019/11/logo-02-2.png",
              "alt": ""
            }
          ]
        },
        {
          "type": "1_6",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "src": "https://diviplus.io/wp-content/uploads/2019/11/logo-01-1.png",
              "alt": ""
            }
          ]
        }
      ]
    }
  ]
}