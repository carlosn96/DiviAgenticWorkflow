{
  "type": "regular",
  "module": "divi/section",
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "background": {
          "desktop": {
            "value": {
              "color": "rgba(158,146,130,0.28)"
            }
          }
        },
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "left": "40px"
              }
            }
          }
        },
        "border": {
          "desktop": {
            "value": {
              "radius": {
                "topLeft": "20px",
                "topRight": "",
                "bottomRight": "",
                "bottomLeft": "20px"
              }
            }
          }
        },
        "boxShadow": {
          "desktop": {
            "value": {
              "style": "preset1",
              "color": "rgba(26,24,20,0.14)"
            }
          }
        }
      },
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "content": "{{slot:gallery[0].title}}",
              "level": "h2"
            },
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "decoration": {
            "border": {
              "desktop": {
                "value": {
                  "radius": {
                    "topLeft": "250px",
                    "topRight": "",
                    "bottomRight": "",
                    "bottomLeft": "250px"
                  }
                }
              }
            }
          },
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "src": "{{slot:gallery[0].image}}",
              "alt": ""
            }
          ]
        }
      ]
    }
  ]
}