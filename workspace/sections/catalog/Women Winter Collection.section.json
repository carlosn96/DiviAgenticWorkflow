{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "rgba(139,58,58,0.15)"
        }
      }
    },
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "150px",
            "bottom": "0px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "top": "0px",
                "bottom": "0px"
              }
            }
          }
        }
      },
      "column_structure": "3_5,2_5",
      "columns": [
        {
          "type": "3_5",
          "module": "divi/column",
          "decoration": {
            "spacing": {
              "desktop": {
                "value": {
                  "padding": {
                    "bottom": "50px"
                  }
                }
              }
            }
          },
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "20px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:gallery[0].text}}"
            },
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "bottom": "0px"
                      },
                      "margin": {
                        "bottom": "0px"
                      }
                    }
                  }
                }
              }
            }
          ]
        },
        {
          "type": "2_5",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "top": "-150px"
                      }
                    }
                  }
                }
              },
              "src": "{{slot:gallery[0].image}}",
              "alt": "Divi WooCommerce Layout"
            }
          ]
        }
      ]
    }
  ]
}