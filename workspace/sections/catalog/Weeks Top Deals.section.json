{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "{{design:color:parchment-50}}"
        }
      }
    },
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "20px",
            "bottom": "20px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_3,2_3",
      "columns": [
        {
          "type": "1_3",
          "module": "divi/column",
          "decoration": {
            "background": {
              "desktop": {
                "value": {
                  "gradient": {
                    "enabled": "on",
                    "type": "linear",
                    "direction": "180deg",
                    "overlaysImage": "on",
                    "stops": [
                      {
                        "color": "rgba(0,0,0,0.6)",
                        "position": "0%"
                      },
                      {
                        "color": "rgba(0,0,0,0)",
                        "position": "100%"
                      }
                    ]
                  },
                  "image": {
                    "url": "https://diviplus.io/wp-content/uploads/2019/11/dp-gs13.webp",
                    "size": "cover",
                    "position": "center center",
                    "repeat": "no-repeat",
                    "parallax": {
                      "enabled": "off"
                    }
                  }
                }
              }
            },
            "spacing": {
              "desktop": {
                "value": {
                  "padding": {
                    "top": "20%"
                  }
                }
              }
            }
          },
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "50px"
                      }
                    }
                  }
                }
              }
            },
            {
              "type": "divi/button",
              "module": "divi/button",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "50px"
                      }
                    }
                  }
                }
              },
              "button_text": "{{slot:btn_primary_text}}",
              "button_url": "{{slot:btn_primary_url}}"
            }
          ]
        },
        {
          "type": "2_3",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}"
            },
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            }
          ]
        }
      ]
    }
  ]
}