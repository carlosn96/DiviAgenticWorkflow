{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "0px",
            "bottom": "0px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "top": "0px",
                "right": "5%",
                "bottom": "0px"
              }
            }
          }
        }
      },
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "decoration": {
                "border": {
                  "desktop": {
                    "value": {
                      "radius": {
                        "topLeft": "50%",
                        "topRight": "50%",
                        "bottomRight": "",
                        "bottomLeft": ""
                      }
                    }
                  }
                }
              },
              "src": "{{slot:gallery[0].image}}",
              "alt": ""
            },
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "10px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:gallery[0].title}}",
              "level": "h2"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "30px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:gallery[0].text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:ink}}"
                  }
                }
              }
            },
            {
              "type": "divi/button",
              "module": "divi/button",
              "button_text": "{{slot:gallery[0].btn_text}}",
              "button_url": "{{slot:gallery[0].btn_url}}"
            }
          ]
        }
      ]
    }
  ]
}