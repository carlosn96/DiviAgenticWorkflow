{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "gradient": {
            "enabled": "on",
            "type": "linear",
            "direction": "180deg",
            "overlaysImage": "on",
            "stops": [
              {
                "color": "rgba(26,24,20,0.51)",
                "position": "0%"
              },
              {
                "color": "rgba(26,24,20,0.52)",
                "position": "100%"
              }
            ]
          },
          "image": {
            "url": "https://diviplus.io/wp-content/uploads/2020/09/horizon-light-bridge-skyline-night-town-971483-pxhere.com_.jpg",
            "size": "cover",
            "position": "center center",
            "repeat": "no-repeat",
            "parallax": {
              "enabled": "off"
            }
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "top": "0px",
                "bottom": "0px"
              }
            }
          }
        }
      },
      "column_structure": "1_3,2_3",
      "columns": [
        {
          "type": "1_3",
          "module": "divi/column",
          "decoration": {
            "spacing": {
              "desktop": {
                "value": {
                  "padding": {
                    "top": "4%",
                    "right": "4%",
                    "bottom": "4%",
                    "left": "4%"
                  }
                }
              }
            }
          },
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "bottom": "30px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:eyebrow}}"
            },
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "30px",
                        "bottom": "30px"
                      }
                    }
                  }
                }
              },
              "title": "hello@example.com",
              "content": "",
              "src": ""
            },
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "30px",
                        "bottom": "30px"
                      }
                    }
                  }
                }
              },
              "title": "0123456789",
              "content": "",
              "src": ""
            },
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "30px",
                        "bottom": "30px"
                      }
                    }
                  }
                }
              },
              "title": "Address",
              "content": "890 Lorem Ipsum Street #12\nAlabama, United States",
              "src": ""
            }
          ]
        },
        {
          "type": "2_3",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "40px",
                        "right": "40px",
                        "bottom": "40px",
                        "left": "40px"
                      },
                      "margin": {
                        "bottom": "1px"
                      }
                    }
                  }
                }
              }
            }
          ]
        }
      ]
    }
  ]
}