{
  "type": "regular",
  "module": "divi/section",
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "4_4",
      "columns": [
        {
          "type": "4_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "10px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:title}}",
              "level": "h2"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:ink}}"
                  }
                }
              }
            }
          ]
        }
      ]
    },
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "top": "0px",
                "bottom": "0px"
              },
              "margin": {
                "top": "30px",
                "bottom": "30px"
              }
            }
          }
        },
        "boxShadow": {
          "desktop": {
            "value": {
              "style": "preset1",
              "color": "rgba(26,24,20,0.08)"
            }
          }
        }
      },
      "column_structure": "4_4",
      "columns": [
        {
          "type": "4_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            },
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            }
          ]
        }
      ]
    }
  ]
}