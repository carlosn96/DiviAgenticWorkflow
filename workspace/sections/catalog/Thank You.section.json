{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "image": {
            "url": "https://diviplus.io/wp-content/uploads/2024/11/thank-you-background.webp?_t=1731660810",
            "size": "cover",
            "position": "center center",
            "repeat": "no-repeat",
            "parallax": {
              "enabled": "off"
            }
          }
        }
      }
    },
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "100px",
            "bottom": "100px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "background": {
          "desktop": {
            "value": {
              "color": "rgba(253,251,247,0.7)"
            }
          }
        },
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "top": "50px",
                "right": "50px",
                "bottom": "50px",
                "left": "50px"
              }
            }
          }
        }
      },
      "column_structure": "4_4",
      "columns": [
        {
          "type": "4_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}"
            },
            {
              "type": "divi/divider",
              "module": "divi/divider",
              "show_divider": "on"
            }
          ]
        }
      ]
    }
  ]
}