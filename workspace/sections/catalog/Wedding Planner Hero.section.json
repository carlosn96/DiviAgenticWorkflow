{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "gradient": {
            "enabled": "on",
            "type": "linear",
            "direction": "90deg",
            "overlaysImage": "on",
            "stops": [
              {
                "color": "{{design:color:parchment-50}}",
                "position": "0%"
              },
              {
                "color": "{{design:color:sepia-100}}",
                "position": "100%"
              }
            ]
          }
        }
      }
    },
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "bottom": "0px"
          },
          "margin": {
            "bottom": "50px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:eyebrow}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "rgba(61,107,79,0.1)",
                    "size": "7vw"
                  }
                }
              }
            },
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "top": "-50px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:title}}",
              "level": "h2"
            },
            {
              "type": "divi/image",
              "module": "divi/image",
              "src": "",
              "alt": ""
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "right": "-100px"
                      }
                    }
                  }
                }
              },
              "src": "",
              "alt": ""
            },
            {
              "type": "divi/image",
              "module": "divi/image",
              "src": "https://themes.diviplus.io/wedding-planner/wp-content/uploads/2021/11/dp-wedding-planner02.webp",
              "alt": ""
            }
          ]
        }
      ]
    }
  ]
}