{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "3%",
            "bottom": "5%"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "background": {
          "desktop": {
            "value": {
              "gradient": {
                "enabled": "on",
                "type": "linear",
                "direction": "270deg",
                "overlaysImage": "on",
                "stops": [
                  {
                    "color": "{{design:color:parchment-50}}",
                    "position": "0%"
                  },
                  {
                    "color": "rgba(61,107,79,0.0)",
                    "position": "100%"
                  }
                ]
              },
              "image": {
                "url": "https://diviplus.io/wp-content/uploads/2021/02/landscape-architecture-wood-lawn.jpg",
                "size": "cover",
                "position": "center center",
                "repeat": "no-repeat",
                "parallax": {
                  "enabled": "off"
                }
              }
            }
          }
        },
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "top": "7%",
                "bottom": "7%"
              }
            }
          }
        }
      },
      "column_structure": "2_5,3_5",
      "columns": [
        {
          "type": "2_5",
          "module": "divi/column",
          "modules": []
        },
        {
          "type": "3_5",
          "module": "divi/column",
          "decoration": {
            "background": {
              "desktop": {
                "value": {
                  "color": "{{design:color:parchment-50}}"
                }
              }
            },
            "spacing": {
              "desktop": {
                "value": {
                  "padding": {
                    "top": "60px",
                    "right": "60px",
                    "bottom": "60px",
                    "left": "60px"
                  }
                }
              }
            },
            "boxShadow": {
              "desktop": {
                "value": {
                  "style": "preset1",
                  "color": "rgba(26,24,20,0.15)"
                }
              }
            }
          },
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "20px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:eyebrow}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:accent}}"
                  }
                }
              }
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "20px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:text}}"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "size": "16px"
                  }
                }
              }
            },
            {
              "type": "divi/button",
              "module": "divi/button",
              "button_text": "{{slot:btn_primary_text}}",
              "button_url": "{{slot:btn_primary_url}}"
            }
          ]
        }
      ]
    }
  ]
}