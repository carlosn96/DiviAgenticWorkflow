{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "bottom": "0px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "bottom": "100px"
              }
            }
          }
        }
      },
      "column_structure": "3_4,1_4",
      "columns": [
        {
          "type": "3_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "content": "{{slot:title}}",
              "level": "h2"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}"
            },
            {
              "type": "divi/button",
              "module": "divi/button",
              "button_text": "{{slot:btn_primary_text}}",
              "button_url": "{{slot:btn_primary_url}}"
            }
          ]
        },
        {
          "type": "1_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "0px"
                      }
                    }
                  }
                }
              },
              "title": "17K+",
              "content": "<p>Visitors</p>",
              "src": ""
            }
          ]
        }
      ]
    },
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "bottom": "0px"
              }
            }
          }
        }
      },
      "column_structure": "1_3,1_3,1_3",
      "columns": [
        {
          "type": "1_3",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "src": "",
              "alt": ""
            }
          ]
        },
        {
          "type": "1_3",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "top": "-80px"
                      }
                    }
                  }
                }
              },
              "src": "https://themes.diviplus.io/landing-meetup/wp-content/uploads/2023/11/girl-in-specs-work.webp",
              "alt": ""
            }
          ]
        },
        {
          "type": "1_3",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "src": "",
              "alt": ""
            }
          ]
        }
      ]
    }
  ]
}