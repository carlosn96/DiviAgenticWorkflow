{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "0px",
            "right": "0px",
            "bottom": "0px",
            "left": "0px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "background": {
          "desktop": {
            "value": {
              "color": "{{design:color:parchment-300}}",
              "image": {
                "url": "https://diviplus.io/wp-content/uploads/2019/11/circle-background-pattern.png",
                "size": "cover",
                "position": "center center",
                "repeat": "no-repeat",
                "parallax": {
                  "enabled": "off"
                }
              }
            }
          }
        },
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "top": "0px",
                "bottom": "0px"
              }
            }
          }
        }
      },
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "decoration": {
            "spacing": {
              "desktop": {
                "value": {
                  "padding": {
                    "top": "10%",
                    "right": "5%",
                    "bottom": "10%",
                    "left": "5%"
                  }
                }
              }
            }
          },
          "modules": [
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "content": "{{slot:title}}",
              "level": "h2"
            },
            {
              "type": "divi/button",
              "module": "divi/button",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "80px",
                        "bottom": "80px"
                      }
                    }
                  }
                }
              },
              "button_text": "{{slot:btn_primary_text}}",
              "button_url": "{{slot:btn_primary_url}}"
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "decoration": {
            "background": {
              "desktop": {
                "value": {
                  "image": {
                    "url": "https://diviplus.io/wp-content/uploads/2021/01/puupy-dog-brown-bg.jpg",
                    "size": "cover",
                    "position": "center center",
                    "repeat": "no-repeat",
                    "parallax": {
                      "enabled": "on"
                    }
                  }
                }
              }
            }
          },
          "modules": []
        }
      ]
    }
  ]
}