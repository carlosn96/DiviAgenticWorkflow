{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "bottom": "0px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "src": "",
              "alt": ""
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/row-inner",
              "module": "divi/row-inner",
              "column_structure": "4_4",
              "columns": [
                {
                  "type": "4_4",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/text",
                      "module": "divi/text",
                      "decoration": {
                        "spacing": {
                          "desktop": {
                            "value": {
                              "margin": {
                                "top": "10px",
                                "bottom": "10px"
                              }
                            }
                          }
                        }
                      },
                      "content": "{{slot:text}}"
                    },
                    {
                      "type": "divi/heading",
                      "module": "divi/heading",
                      "decoration": {
                        "spacing": {
                          "desktop": {
                            "value": {
                              "margin": {
                                "top": "2px",
                                "bottom": "10px"
                              }
                            }
                          }
                        }
                      },
                      "content": "{{slot:title}}",
                      "level": "h2"
                    },
                    {
                      "type": "divi/text",
                      "module": "divi/text",
                      "content": "{{slot:text}}"
                    }
                  ]
                }
              ]
            },
            {
              "type": "divi/row-inner",
              "module": "divi/row-inner",
              "column_structure": "1_2,1_2",
              "columns": [
                {
                  "type": "1_2",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/placeholder",
                      "module": "divi/placeholder",
                      "decoration": {
                        "background": {
                          "desktop": {
                            "value": {
                              "color": "{{design:color:parchment-100}}"
                            }
                          }
                        },
                        "spacing": {
                          "desktop": {
                            "value": {
                              "padding": {
                                "top": "10px",
                                "right": "10px",
                                "bottom": "10px",
                                "left": "10px"
                              }
                            }
                          }
                        }
                      }
                    },
                    {
                      "type": "divi/placeholder",
                      "module": "divi/placeholder",
                      "decoration": {
                        "background": {
                          "desktop": {
                            "value": {
                              "color": "{{design:color:parchment-100}}"
                            }
                          }
                        },
                        "spacing": {
                          "desktop": {
                            "value": {
                              "padding": {
                                "top": "10px",
                                "right": "10px",
                                "bottom": "10px",
                                "left": "10px"
                              }
                            }
                          }
                        }
                      }
                    }
                  ]
                },
                {
                  "type": "1_2",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/placeholder",
                      "module": "divi/placeholder",
                      "decoration": {
                        "background": {
                          "desktop": {
                            "value": {
                              "color": "{{design:color:parchment-100}}"
                            }
                          }
                        },
                        "spacing": {
                          "desktop": {
                            "value": {
                              "padding": {
                                "top": "10px",
                                "right": "10px",
                                "bottom": "10px",
                                "left": "10px"
                              }
                            }
                          }
                        }
                      }
                    },
                    {
                      "type": "divi/placeholder",
                      "module": "divi/placeholder",
                      "decoration": {
                        "background": {
                          "desktop": {
                            "value": {
                              "color": "{{design:color:parchment-100}}"
                            }
                          }
                        },
                        "spacing": {
                          "desktop": {
                            "value": {
                              "padding": {
                                "top": "10px",
                                "right": "10px",
                                "bottom": "10px",
                                "left": "10px"
                              }
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}