{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "{{design:color:ink}}"
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "4_4",
      "columns": [
        {
          "type": "4_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}"
            }
          ]
        }
      ]
    },
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "decoration": {
                "border": {
                  "desktop": {
                    "value": {
                      "radius": {
                        "topLeft": "4px",
                        "topRight": "4px",
                        "bottomRight": "4px",
                        "bottomLeft": "4px"
                      }
                    }
                  }
                },
                "boxShadow": {
                  "desktop": {
                    "value": {
                      "style": "preset4",
                      "color": "{{design:color:accent}}"
                    }
                  }
                }
              },
              "src": "{{slot:gallery[0].image}}",
              "alt": ""
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            }
          ]
        }
      ]
    }
  ]
}