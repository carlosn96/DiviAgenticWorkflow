{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "70px",
            "bottom": "70px"
          },
          "margin": {
            "top": "0px",
            "bottom": "0px"
          }
        }
      }
    },
    "boxShadow": {
      "desktop": {
        "value": {
          "style": "preset1",
          "color": "rgba(26,24,20,0.1)"
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "right": "15%",
                "left": "15%"
              }
            }
          }
        }
      },
      "column_structure": "1_3,1_3,1_3",
      "columns": [
        {
          "type": "1_3",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "0px",
                        "bottom": "0px"
                      },
                      "margin": {
                        "top": "0px",
                        "bottom": "0px"
                      }
                    }
                  }
                }
              }
            }
          ]
        }
      ]
    }
  ]
}