{
  "type": "regular",
  "module": "divi/section",
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "src": "{{slot:gallery[0].image}}",
              "alt": ""
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "decoration": {
            "spacing": {
              "desktop": {
                "value": {
                  "padding": {
                    "top": "60px"
                  }
                }
              }
            }
          },
          "modules": [
            {
              "type": "divi/divider",
              "module": "divi/divider",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "30px"
                      }
                    }
                  }
                }
              },
              "show_divider": "on"
            }
          ]
        }
      ]
    }
  ]
}