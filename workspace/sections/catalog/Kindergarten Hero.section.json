{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "{{design:color:parchment-100}}"
        }
      }
    },
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "150px",
            "bottom": "200px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "10px"
                      }
                    }
                  }
                }
              }
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "top": "40px",
                        "bottom": "45px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:text}}"
            },
            {
              "type": "divi/button",
              "module": "divi/button",
              "button_text": "{{slot:btn_primary_text}}",
              "button_url": "{{slot:btn_primary_url}}"
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/row-inner",
              "module": "divi/row-inner",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "0px",
                        "bottom": "0px"
                      }
                    }
                  }
                }
              },
              "column_structure": "1_2,1_2",
              "columns": [
                {
                  "type": "1_2",
                  "module": "divi/column-inner",
                  "decoration": {
                    "spacing": {
                      "desktop": {
                        "value": {
                          "padding": {
                            "right": "5px"
                          }
                        }
                      }
                    }
                  },
                  "modules": [
                    {
                      "type": "divi/image",
                      "module": "divi/image",
                      "decoration": {
                        "border": {
                          "desktop": {
                            "value": {
                              "radius": {
                                "topLeft": "300px",
                                "topRight": "",
                                "bottomRight": "",
                                "bottomLeft": ""
                              }
                            }
                          }
                        },
                        "boxShadow": {
                          "desktop": {
                            "value": {
                              "style": "preset5",
                              "color": "{{design:color:premium}}"
                            }
                          }
                        }
                      },
                      "src": "https://themes.diviplus.io/kindergarten/wp-content/uploads/2023/11/dpk-home-header-boy-playing-in-kindergarten.webp",
