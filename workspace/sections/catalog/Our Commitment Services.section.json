                {
                  "type": "4_4",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/text",
                      "module": "divi/text",
                      "decoration": {
                        "spacing": {
                          "desktop": {
                            "value": {
                              "margin": {
                                "bottom": "0px"
                              }
                            }
                          }
                        }
                      },
                      "content": "{{slot:eyebrow}}"
