{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "gradient": {
            "enabled": "on",
            "type": "linear",
            "direction": "90deg",
            "overlaysImage": "on",
            "stops": [
              {
                "color": "rgba(0,0,0,0.6)",
                "position": "0%"
              },
              {
                "color": "rgba(0,0,0,0)",
                "position": "100%"
              }
            ]
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2,1_4,1_4",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            }
          ]
        },
        {
          "type": "1_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "10px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:gallery[1].title}}",
              "level": "h2"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:gallery[1].text}}"
            },
            {
              "type": "divi/button",
              "module": "divi/button",
              "button_text": "{{slot:gallery[1].btn_text}}",
              "button_url": "{{slot:gallery[1].btn_url}}"
            }
          ]
        },
        {
          "type": "1_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            }
          ]
        }
      ]
    }
  ]
}