{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "0px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "background": {
          "desktop": {
            "value": {
              "color": "rgba(26,24,20,0.6)",
              "image": {
                "url": "https://diviplus.io/wp-content/uploads/2024/11/man-light-black-and-white-white-photograp-bg.webp?_t=1732012880",
                "size": "cover",
                "position": "center center",
                "repeat": "no-repeat",
                "parallax": {
                  "enabled": "off"
                }
              }
            }
          }
        },
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "top": "0px"
              },
              "margin": {
                "bottom": "0px"
              }
            }
          }
        }
      },
      "column_structure": "4_4",
      "columns": [
        {
          "type": "4_4",
          "module": "divi/column",
          "decoration": {
            "spacing": {
              "desktop": {
                "value": {
                  "padding": {
                    "bottom": "0px"
                  }
                }
              }
            }
          },
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}"
            }
          ]
        }
      ]
    },
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "bottom": "0px"
              }
            }
          }
        }
      },
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "decoration": {
            "background": {
              "desktop": {
                "value": {
                  "color": "{{design:color:ink}}"
                }
              }
            },
            "spacing": {
              "desktop": {
                "value": {
                  "padding": {
                    "top": "30px",
                    "right": "30px",
                    "bottom": "30px",
                    "left": "30px"
                  }
                }
              }
            },
            "border": {
              "desktop": {
                "value": {
                  "radius": {
                    "topLeft": "20px",
                    "topRight": "20px",
                    "bottomRight": "20px",
                    "bottomLeft": "20px"
                  }
                }
              }
            }
          },
          "modules": [
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "10px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:title}}",
              "level": "h2"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:parchment-50}}"
                  }
                }
              }
            },
            {
              "type": "divi/button",
              "module": "divi/button",
              "button_text": "{{slot:btn_primary_text}}",
              "button_url": "{{slot:btn_primary_url}}"
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "title": "Call",
              "content": "<p><a href=\"tel:+000-000-0000\">+000-000-0000</a></p>",
              "src": ""
            },
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "title": "E-Mail",
              "content": "<p><a href=\"mailto:hello@example.com\">hello@example.com</a></p>",
              "src": ""
            },
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "title": "Address",
              "content": "<p>Street, City, State, Country</p>",
              "src": ""
            }
          ]
        }
      ]
    }
  ]
}