{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "gradient": {
            "enabled": "on",
            "type": "linear",
            "direction": "90deg",
            "overlaysImage": "on",
            "stops": [
              {
                "color": "{{design:color:parchment-50}}",
                "position": "0%"
              },
              {
                "color": "rgba(0,0,0,0)",
                "position": "100%"
              }
            ]
          },
          "image": {
            "url": "https://diviplus.io/wp-content/uploads/2021/01/dp-yoga-morning-header-bg.jpg",
            "size": "cover",
            "position": "center center",
            "repeat": "no-repeat",
            "parallax": {
              "enabled": "off"
            }
          }
        }
      }
    },
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "6%",
            "bottom": "6%"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "3_5,2_5",
      "columns": [
        {
          "type": "3_5",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "2%"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:title}}",
              "level": "h2"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}"
            },
            {
              "type": "divi/button",
              "module": "divi/button",
              "button_text": "{{slot:btn_primary_text}}",
              "button_url": "{{slot:btn_primary_url}}"
            }
          ]
        },
        {
          "type": "2_5",
          "module": "divi/column",
          "modules": []
        }
      ]
    }
  ]
}