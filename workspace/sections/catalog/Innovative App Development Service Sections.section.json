{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "spacing": {
      "desktop": {
        "value": {
          "margin": {
            "top": "-1px",
            "bottom": "-1px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "background": {
          "desktop": {
            "value": {
              "gradient": {
                "enabled": "on",
                "type": "elliptical",
                "direction": "180deg",
                "overlaysImage": "on",
                "stops": [
                  {
                    "color": "rgba(0,0,0,0.6)",
                    "position": "0%"
                  },
                  {
                    "color": "rgba(0,0,0,0)",
                    "position": "100%"
                  }
                ]
              }
            }
          }
        }
      },
      "column_structure": "1_3,2_3",
      "columns": [
        {
          "type": "1_3",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "0px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:features[0].text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:parchment-300}}",
                    "size": "18px"
                  }
                }
              }
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:features[0].text}}"
            },
            {
              "type": "divi/button",
              "module": "divi/button",
              "button_text": "{{slot:features[0].btn_text}}",
              "button_url": "{{slot:features[0].btn_url}}"
            }
          ]
        },
        {
          "type": "2_3",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            }
          ]
        }
      ]
    }
  ]
}