{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "0px",
            "bottom": "0px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "10px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:text}}"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "40px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:parchment-50}}",
                    "size": "16px"
                  }
                }
              }
            },
            {
              "type": "divi/button",
              "module": "divi/button",
              "button_text": "{{slot:btn_primary_text}}",
              "button_url": "{{slot:btn_primary_url}}"
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/row-inner",
              "module": "divi/row-inner",
              "decoration": {
                "background": {
                  "desktop": {
                    "value": {
                      "color": "{{design:color:parchment-100}}"
                    }
                  }
                },
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "right": "100px",
                        "left": "100px"
                      }
                    }
                  }
                }
              },
              "column_structure": "4_4",
              "columns": [
                {
                  "type": "4_4",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/blurb",
                      "module": "divi/blurb",
                      "title": "Church Visiting Hours",
                      "content": "",
                      "src": ""
                    },
                    {
                      "type": "divi/placeholder",
                      "module": "divi/placeholder",
                      "decoration": {
                        "spacing": {
                          "desktop": {
                            "value": {
                              "margin": {
                                "bottom": "40px"
                              }
                            }
                          }
                        }
                      }
                    },
                    {
                      "type": "divi/blurb",
                      "module": "divi/blurb",
                      "title": "Address",
                      "content": "635 Lorem Ipsum, Street, City, State, Country",
                      "src": ""
                    }
                  ]
                }
              ]
            },
            {
              "type": "divi/row-inner",
              "module": "divi/row-inner",
              "decoration": {
                "background": {
                  "desktop": {
                    "value": {
                      "color": "{{design:color:error}}"
                    }
                  }
                },
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "right": "100px",
                        "left": "100px"
                      }
                    }
                  }
                }
              },
              "column_structure": "4_4",
              "columns": [
                {
                  "type": "4_4",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/blurb",
                      "module": "divi/blurb",
                      "decoration": {
                        "spacing": {
                          "desktop": {
                            "value": {
                              "margin": {
                                "bottom": "40px"
                              }
                            }
                          }
                        }
                      },
                      "title": "Email",
                      "content": "<a href=\"mailto:abc@example.com\">abc@example.com</a>",
                      "src": ""
                    },
                    {
                      "type": "divi/blurb",
                      "module": "divi/blurb",
                      "title": "Phone",
                      "content": "<a href=\"tel:000-000-0000\">000-000-0000</a>",
                      "src": ""
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}