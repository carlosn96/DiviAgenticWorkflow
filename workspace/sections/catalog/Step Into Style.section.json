{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "30px",
            "bottom": "30px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "4_4",
      "columns": [
        {
          "type": "4_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "content": "{{slot:title}}",
              "level": "h2"
            }
          ]
        }
      ]
    },
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_3,1_3,1_3",
      "columns": [
        {
          "type": "1_3",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "boxShadow": {
                  "desktop": {
                    "value": {
                      "style": "preset1",
                      "color": "{{design:color:success}}"
                    }
                  }
                }
              }
            }
          ]
        },
        {
          "type": "1_3",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "boxShadow": {
                  "desktop": {
                    "value": {
                      "style": "preset1",
                      "color": "{{design:color:accent}}"
                    }
                  }
                }
              }
            }
          ]
        },
        {
          "type": "1_3",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "boxShadow": {
                  "desktop": {
                    "value": {
                      "style": "preset1",
                      "color": "{{design:color:parchment-300}}"
                    }
                  }
                }
              }
            }
          ]
        }
      ]
    }
  ]
}