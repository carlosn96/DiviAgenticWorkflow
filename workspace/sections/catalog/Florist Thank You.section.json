{
  "type": "regular",
  "module": "divi/section",
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "background": {
          "desktop": {
            "value": {
              "image": {
                "url": "https://diviplus.io/wp-content/uploads/2024/11/florist-thank-you-image.webp?_t=1732001066",
                "size": "cover",
                "position": "center center",
                "repeat": "no-repeat",
                "parallax": {
                  "enabled": "off"
                }
              }
            }
          }
        },
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "top": "60px",
                "right": "30px",
                "bottom": "90px",
                "left": "30px"
              }
            }
          }
        }
      },
      "column_structure": "4_4",
