{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "gradient": {
            "enabled": "on",
            "type": "linear",
            "direction": "90deg",
            "overlaysImage": "on",
            "stops": [
              {
                "color": "{{design:color:premium}}",
                "position": "0%"
              },
              {
                "color": "rgba(253,251,247,0.0)",
                "position": "100%"
              }
            ]
          },
          "image": {
            "url": "https://diviplus.io/wp-content/uploads/2020/11/tea-restaurant-dish-meal-food-cooking-22159-pxhere.jpg",
            "size": "cover",
            "position": "center center",
            "repeat": "no-repeat",
            "parallax": {
              "enabled": "off"
            }
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            },
            {
              "type": "divi/button",
              "module": "divi/button",
              "decoration": {
                "border": {
                  "desktop": {
                    "value": {
                      "radius": {
                        "topLeft": "50px",
                        "topRight": "50px",
                        "bottomRight": "50px",
                        "bottomLeft": "50px"
                      }
                    }
                  }
                }
              },
              "button_text": "{{slot:btn_primary_text}}",
              "button_url": "{{slot:btn_primary_url}}"
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "title": "",
              "content": "Lorem ipsum dolor sit amet, consectetur adipiscing elit sed do.",
              "src": ""
            },
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "title": "",
              "content": "Lorem ipsum dolor sit amet, consectetur adipiscing elit sed do.",
              "src": ""
            }
          ]
        }
      ]
    }
  ]
}