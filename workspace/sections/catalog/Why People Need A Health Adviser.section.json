{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "{{design:color:parchment-100}}",
          "gradient": {
            "enabled": "on",
            "type": "linear",
            "direction": "90deg",
            "overlaysImage": "on",
            "stops": [
              {
                "color": "rgba(0,0,0,0.6)",
                "position": "0%"
              },
              {
                "color": "rgba(0,0,0,0)",
                "position": "100%"
              }
            ]
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "src": "https://diviplus.io/wp-content/uploads/2019/11/glass-white.webp",
              "alt": ""
            }
          ]
        }
      ]
    }
  ]
}