{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "gradient": {
            "enabled": "on",
            "type": "linear",
            "direction": "270deg",
            "overlaysImage": "on",
            "stops": [
              {
                "color": "rgba(26,24,20,0.03)",
                "position": "0%"
              },
              {
                "color": "rgba(26,24,20,0.75)",
                "position": "100%"
              }
            ]
          },
          "image": {
            "url": "https://diviplus.io/wp-content/uploads/2021/02/architecture-structure-sky-house-wind-roof-861272-pxhere-1-1.jpg",
            "size": "cover",
            "position": "center center",
            "repeat": "no-repeat",
            "parallax": {
              "enabled": "off"
            }
          }
        }
      }
    },
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "7%",
            "bottom": "7%"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "2_3,1_3",
      "columns": [
        {
          "type": "2_3",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "20px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:eyebrow}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:parchment-50}}"
                  }
                }
              }
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "0px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:eyebrow}}"
            },
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "20px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:title}}",
              "level": "h2"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "left": "20px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:parchment-50}}",
                    "size": "16px"
                  }
                }
              }
            },
            {
              "type": "divi/button",
              "module": "divi/button",
              "button_text": "{{slot:btn_primary_text}}",
              "button_url": "{{slot:btn_primary_url}}"
            }
          ]
        },
        {
          "type": "1_3",
          "module": "divi/column",
          "decoration": {
            "background": {
              "desktop": {
                "value": {
                  "color": "{{design:color:parchment-50}}"
                }
              }
            },
            "spacing": {
              "desktop": {
                "value": {
                  "padding": {
                    "right": "30px",
                    "left": "30px"
                  }
                }
              }
            },
            "border": {
              "desktop": {
                "value": {
                  "radius": {
                    "topLeft": "5px",
                    "topRight": "5px",
                    "bottomRight": "5px",
                    "bottomLeft": "5px"
                  }
                }
              }
            },
            "boxShadow": {
              "desktop": {
                "value": {
                  "style": "preset5",
                  "color": "rgba(253,251,247,0.49)"
                }
              }
            }
          },
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "50px",
                        "bottom": "0px"
                      },
                      "margin": {
                        "bottom": "25px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:parchment-700}}",
                    "size": "16px"
                  }
                }
              }
            },
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "0px",
                        "bottom": "50px"
                      }
                    }
                  }
                }
              }
            }
          ]
        }
      ]
    }
  ]
}