{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "gradient": {
            "enabled": "on",
            "type": "linear",
            "direction": "180deg",
            "overlaysImage": "on",
            "stops": [
              {
                "color": "rgba(0,0,0,0.6)",
                "position": "0%"
              },
              {
                "color": "rgba(0,0,0,0)",
                "position": "100%"
              }
            ]
          },
          "image": {
            "url": "https://themes.diviplus.io/music-school/wp-content/uploads/2023/11/dpms-testimonial.webp",
            "size": "cover",
            "position": "center center",
            "repeat": "no-repeat",
            "parallax": {
              "enabled": "off"
            }
          }
        }
      }
    },
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "90px",
            "bottom": "90px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "5px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:testimonials[0].text}}"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "30px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:testimonials[0].text}}"
            },
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "background": {
                  "desktop": {
                    "value": {
                      "color": "rgba(253,251,247,0.6)"
                    }
                  }
                },
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "15px",
                        "right": "15px",
                        "bottom": "15px",
                        "left": "15px"
                      }
                    }
                  }
                },
                "border": {
                  "desktop": {
                    "value": {
                      "radius": {
                        "topLeft": "10px",
                        "topRight": "10px",
                        "bottomRight": "10px",
                        "bottomLeft": "10px"
                      }
                    }
                  }
                }
              }
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": []
        }
      ]
    }
  ]
}