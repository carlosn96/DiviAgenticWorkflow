{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "gradient": {
            "enabled": "on",
            "type": "linear",
            "direction": "90deg",
            "overlaysImage": "on",
            "stops": [
              {
                "color": "rgba(0,0,0,0.6)",
                "position": "0%"
              },
              {
                "color": "rgba(0,0,0,0)",
                "position": "100%"
              }
            ]
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "background": {
          "desktop": {
            "value": {
              "color": "{{design:color:parchment-50}}"
            }
          }
        },
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "top": "40px",
                "right": "40px",
                "bottom": "40px",
                "left": "40px"
              }
            }
          }
        },
        "border": {
          "desktop": {
            "value": {
              "radius": {
                "topLeft": "20px",
                "topRight": "20px",
                "bottomRight": "20px",
                "bottomLeft": "20px"
              }
            }
          }
        },
        "boxShadow": {
          "desktop": {
            "value": {
              "style": "preset1",
              "color": "rgba(26,24,20,0.06)"
            }
          }
        }
      },
      "column_structure": "2_5,3_5",
      "columns": [
        {
          "type": "2_5",
          "module": "divi/column",
          "decoration": {
            "background": {
              "desktop": {
                "value": {
                  "color": "RGBA(255,255,255,0)"
                }
              }
            }
          },
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "background": {
                  "desktop": {
                    "value": {
                      "color": "RGBA(255,255,255,0)"
                    }
                  }
                },
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "0px",
                        "right": "0px",
                        "bottom": "0px",
                        "left": "0px"
                      }
                    }
                  }
                },
                "layout": {
                  "desktop": {
                    "value": {
                      "textAlign": "left"
                    }
                  }
                }
              }
            },
            {
              "type": "divi/button",
              "module": "divi/button",
              "button_text": "{{slot:features[0].btn_text}}",
              "button_url": "{{slot:features[0].btn_url}}"
            }
          ]
        },
        {
          "type": "3_5",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/icon-list",
              "module": "divi/icon-list",
              "children": [
                {
                  "type": "divi/icon-list-item",
                  "module": "divi/icon-list-item",
                  "content": ""
                },
                {
                  "type": "divi/icon-list-item",
                  "module": "divi/icon-list-item",
                  "content": ""
                },
                {
                  "type": "divi/icon-list-item",
                  "module": "divi/icon-list-item",
                  "content": ""
                },
                {
                  "type": "divi/icon-list-item",
                  "module": "divi/icon-list-item",
                  "content": ""
                },
                {
                  "type": "divi/icon-list-item",
                  "module": "divi/icon-list-item",
                  "content": ""
                },
                {
                  "type": "divi/icon-list-item",
                  "module": "divi/icon-list-item",
                  "content": ""
                },
                {
                  "type": "divi/icon-list-item",
                  "module": "divi/icon-list-item",
                  "content": ""
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}