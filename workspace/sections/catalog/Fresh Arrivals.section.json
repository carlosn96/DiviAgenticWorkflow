{
  "type": "regular",
  "module": "divi/section",
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/row-inner",
              "module": "divi/row-inner",
              "column_structure": "4_4",
              "columns": [
                {
                  "type": "4_4",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/text",
                      "module": "divi/text",
                      "decoration": {
                        "spacing": {
                          "desktop": {
                            "value": {
                              "margin": {
                                "bottom": "10px"
                              }
                            }
                          }
                        }
                      },
                      "content": "{{slot:eyebrow}}",
                      "bodyFont": {
                        "desktop": {
                          "value": {
                            "fontFamily": "{{design:font:body}}",
                            "color": "{{design:color:error}}"
                          }
                        }
                      }
                    },
                    {
                      "type": "divi/heading",
                      "module": "divi/heading",
                      "content": "{{slot:title}}",
                      "level": "h2"
                    }
                  ]
                }
              ]
            },
            {
              "type": "divi/row-inner",
              "module": "divi/row-inner",
              "column_structure": "1_2,1_2",
              "columns": [
                {
                  "type": "1_2",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/image",
                      "module": "divi/image",
                      "src": "{{slot:gallery[0].image}}",
                      "alt": ""
                    }
                  ]
                },
                {
                  "type": "1_2",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/text",
                      "module": "divi/text",
                      "content": "{{slot:gallery[0].text}}"
                    },
                    {
                      "type": "divi/button",
                      "module": "divi/button",
                      "button_text": "{{slot:gallery[0].btn_text}}",
                      "button_url": "{{slot:gallery[0].btn_url}}"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            }
          ]
        }
      ]
    }
  ]
}