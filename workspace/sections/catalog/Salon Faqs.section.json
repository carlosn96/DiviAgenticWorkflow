{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "{{design:color:sepia-100}}"
        }
      }
    },
    "spacing": {
      "desktop": {
        "value": {
          "margin": {
            "top": "120px",
            "bottom": "150px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "background": {
          "desktop": {
            "value": {
              "color": "rgba(253,251,247,0.6)"
            }
          }
        },
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "right": "70px",
                "left": "70px"
              },
              "margin": {
                "top": "-140px",
                "right": "auto",
                "bottom": "-140px",
                "left": "auto"
              }
            }
          }
        },
        "boxShadow": {
          "desktop": {
            "value": {
              "style": "preset1",
              "color": "rgba(26,24,20,0.09)"
            }
          }
        }
      },
      "column_structure": "4_4",
      "columns": [
        {
          "type": "4_4",
          "module": "divi/column",
          "decoration": {
            "spacing": {
              "desktop": {
                "value": {
                  "padding": {
                    "top": "80px",
                    "bottom": "80px"
                  }
                }
              }
            }
          },
          "modules": [
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "content": "{{slot:title}}",
              "level": "h2"
            },
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "40px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:title}}",
              "level": "h2"
            },
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            },
            {
              "type": "divi/image",
              "module": "divi/image",
              "src": "https://themes.diviplus.io/salon/wp-content/uploads/2021/11/dp-salon-04.webp",
              "alt": ""
            }
          ]
        }
      ]
    }
  ]
}