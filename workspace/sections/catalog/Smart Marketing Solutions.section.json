{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "gradient": {
            "enabled": "on",
            "type": "linear",
            "direction": "180deg",
            "overlaysImage": "on",
            "stops": [
              {
                "color": "rgba(0,0,0,0.6)",
                "position": "0%"
              },
              {
                "color": "rgba(0,0,0,0)",
                "position": "100%"
              }
            ]
          }
        }
      }
    },
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "100px",
            "bottom": "100px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "background": {
          "desktop": {
            "value": {
              "gradient": {
                "enabled": "on",
                "type": "linear",
                "direction": "180deg",
                "overlaysImage": "on",
                "stops": [
                  {
                    "color": "rgba(0,0,0,0.6)",
                    "position": "0%"
                  },
                  {
                    "color": "rgba(0,0,0,0)",
                    "position": "100%"
                  }
                ]
              }
            }
          }
        },
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "top": "60px",
                "right": "20px",
                "bottom": "60px",
                "left": "20px"
              }
            }
          }
        },
        "border": {
          "desktop": {
            "value": {
              "radius": {
                "topLeft": "15px",
                "topRight": "15px",
                "bottomRight": "15px",
                "bottomLeft": "15px"
              }
            }
          }
        }
      },
      "column_structure": "1_3,1_3,1_3",
      "columns": [
        {
          "type": "1_3",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "decoration": {
                "layout": {
                  "desktop": {
                    "value": {
                      "textAlign": "center"
                    }
                  }
                }
              },
              "src": "{{slot:gallery[0].image}}",
              "alt": ""
            },
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "2px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:gallery[0].title}}",
              "level": "h2"
            },
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            }
          ]
        },
        {
          "type": "1_3",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "decoration": {
                "layout": {
                  "desktop": {
                    "value": {
                      "textAlign": "center"
                    }
                  }
                }
              },
              "src": "{{slot:gallery[1].image}}",
              "alt": ""
            },
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "2px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:gallery[1].title}}",
              "level": "h2"
            },
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            }
          ]
        },
        {
          "type": "1_3",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "decoration": {
                "layout": {
                  "desktop": {
                    "value": {
                      "textAlign": "center"
                    }
                  }
                }
              },
              "src": "{{slot:gallery[2].image}}",
              "alt": ""
            },
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "2px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:gallery[2].title}}",
              "level": "h2"
            },
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            }
          ]
        }
      ]
    }
  ]
}