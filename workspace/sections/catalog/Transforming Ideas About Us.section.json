{
  "type": "regular",
  "module": "divi/section",
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/row-inner",
              "module": "divi/row-inner",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "bottom": "15px"
                      }
                    }
                  }
                }
              },
              "column_structure": "4_4",
              "columns": [
                {
                  "type": "4_4",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/text",
                      "module": "divi/text",
                      "content": "{{slot:text}}"
                    },
                    {
                      "type": "divi/text",
                      "module": "divi/text",
                      "content": "{{slot:text}}",
                      "bodyFont": {
                        "desktop": {
                          "value": {
                            "fontFamily": "{{design:font:body}}",
                            "color": "{{design:color:ink}}"
                          }
                        }
                      }
                    },
                    {
                      "type": "divi/button",
                      "module": "divi/button",
                      "decoration": {
                        "spacing": {
                          "desktop": {
                            "value": {
                              "padding": {
                                "bottom": "0px"
                              },
                              "margin": {
                                "bottom": "-20px"
                              }
                            }
                          }
                        }
                      },
                      "button_text": "{{slot:btn_primary_text}}",
                      "button_url": "{{slot:btn_primary_url}}"
                    }
                  ]
                }
              ]
            },
            {
              "type": "divi/row-inner",
              "module": "divi/row-inner",
              "decoration": {
                "background": {
                  "desktop": {
                    "value": {
                      "color": "{{design:color:parchment-50}}"
                    }
                  }
                },
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "10px",
                        "bottom": "10px"
                      }
                    }
                  }
                },
                "border": {
                  "desktop": {
                    "value": {
                      "radius": {
                        "topLeft": "20px",
                        "topRight": "20px",
                        "bottomRight": "20px",
                        "bottomLeft": "20px"
                      }
                    }
                  }
                },
                "boxShadow": {
                  "desktop": {
                    "value": {
                      "style": "preset1",
                      "color": "rgba(92,82,68,0.2)"
                    }
                  }
                }
              },
              "column_structure": "1_3,1_3,1_3",
              "columns": [
                {
                  "type": "1_3",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/placeholder",
                      "module": "divi/placeholder"
                    }
                  ]
                },
                {
                  "type": "1_3",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/placeholder",
                      "module": "divi/placeholder"
                    }
                  ]
                },
                {
                  "type": "1_3",
                  "module": "divi/column-inner",
                  "modules": [
                    {
                      "type": "divi/placeholder",
                      "module": "divi/placeholder"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "decoration": {
                "border": {
                  "desktop": {
                    "value": {
                      "radius": {
                        "topLeft": "40px",
                        "topRight": "40px",
                        "bottomRight": "40px",
                        "bottomLeft": "40px"
                      }
                    }
                  }
                }
              },
              "src": "https://diviplus.io/wp-content/uploads/2025/01/african-american-african-descent-afro-analyzing-beverage-black-people.webp?_t=1736421070",
              "alt": ""
            }
          ]
        }
      ]
    }
  ]
}