{
  "type": "regular",
  "module": "divi/section",
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "background": {
          "desktop": {
            "value": {
              "color": "{{design:color:success}}"
            }
          }
        },
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "top": "30px",
                "right": "30px",
                "bottom": "30px",
                "left": "30px"
              }
            }
          }
        },
        "border": {
          "desktop": {
            "value": {
              "radius": {
                "topLeft": "30px",
                "topRight": "30px",
                "bottomRight": "30px",
                "bottomLeft": "30px"
              }
            }
          }
        },
        "boxShadow": {
          "desktop": {
            "value": {
              "style": "preset1"
            }
          }
        }
      },
      "column_structure": "3_4,1_4",
      "columns": [
        {
          "type": "3_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "size": "20px"
                  }
                }
              }
            }
          ]
        },
        {
          "type": "1_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/button",
              "module": "divi/button",
              "decoration": {
                "border": {
                  "desktop": {
                    "value": {
                      "radius": {
                        "topLeft": "5px",
                        "topRight": "5px",
                        "bottomRight": "5px",
                        "bottomLeft": "5px"
                      }
                    }
                  }
                }
              },
              "button_text": "{{slot:btn_primary_text}}",
              "button_url": "{{slot:btn_primary_url}}"
            }
          ]
        }
      ]
    }
  ]
}