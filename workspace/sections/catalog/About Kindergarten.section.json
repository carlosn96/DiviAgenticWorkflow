{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "image": {
            "url": "https://diviplus.io/wp-content/uploads/2019/11/day_care_img_16.png",
            "size": "cover",
            "position": "center center",
            "repeat": "no-repeat",
            "parallax": {
              "enabled": "off"
            }
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "size": "22px"
                  }
                }
              }
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "size": "22px"
                  }
                }
              }
            },
            {
              "type": "divi/button",
              "module": "divi/button",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "top": "40px"
                      }
                    }
                  }
                }
              },
              "button_text": "{{slot:btn_primary_text}}",
              "button_url": "{{slot:btn_primary_url}}"
            }
          ]
        }
      ]
    }
  ]
}