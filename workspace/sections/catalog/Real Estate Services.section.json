{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "gradient": {
            "enabled": "on",
            "type": "linear",
            "direction": "90deg",
            "overlaysImage": "on",
            "stops": [
              {
                "color": "rgba(0,0,0,0.6)",
                "position": "0%"
              },
              {
                "color": "rgba(0,0,0,0)",
                "position": "100%"
              }
            ]
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "2_5,3_5",
      "columns": [
        {
          "type": "2_5",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "decoration": {
                "boxShadow": {
                  "desktop": {
                    "value": {
                      "style": "preset1",
                      "color": "rgba(26,24,20,0.12)"
                    }
                  }
                }
              },
              "src": "{{slot:features[0].image}}",
              "alt": ""
            }
          ]
        },
        {
          "type": "3_5",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "content": "{{slot:features[0].title}}",
              "level": "h2"
            },
            {
              "type": "divi/icon-list",
              "module": "divi/icon-list",
              "children": [
                {
                  "type": "divi/icon-list-item",
                  "module": "divi/icon-list-item",
                  "content": ""
                },
                {
                  "type": "divi/icon-list-item",
                  "module": "divi/icon-list-item",
                  "content": ""
                },
                {
                  "type": "divi/icon-list-item",
                  "module": "divi/icon-list-item",
                  "content": ""
                },
                {
                  "type": "divi/icon-list-item",
                  "module": "divi/icon-list-item",
                  "content": ""
                },
                {
                  "type": "divi/icon-list-item",
                  "module": "divi/icon-list-item",
                  "content": ""
                }
              ]
            },
            {
              "type": "divi/button",
              "module": "divi/button",
              "button_text": "{{slot:features[0].btn_text}}",
              "button_url": "{{slot:features[0].btn_url}}"
            }
          ]
        }
      ]
    }
  ]
}