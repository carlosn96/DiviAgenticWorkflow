{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "{{design:color:parchment-100}}"
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "20px"
                      }
                    }
                  }
                },
                "border": {
                  "desktop": {
                    "value": {
                      "radius": {
                        "topLeft": "",
                        "topRight": "20px",
                        "bottomRight": "",
                        "bottomLeft": "20px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:gallery[0].text}}"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "40px"
                      }
                    }
                  }
                },
                "border": {
                  "desktop": {
                    "value": {
                      "radius": {
                        "topLeft": "",
                        "topRight": "20px",
                        "bottomRight": "",
                        "bottomLeft": "20px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:gallery[0].text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "size": "16px"
                  }
                }
              }
            },
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "border": {
                  "desktop": {
                    "value": {
                      "radius": {
                        "topLeft": "",
                        "topRight": "20px",
                        "bottomRight": "",
                        "bottomLeft": "20px"
                      }
                    }
                  }
                }
              }
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            }
          ]
        }
      ]
    }
  ]
}