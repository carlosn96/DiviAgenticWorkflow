{
  "type": "regular",
  "module": "divi/section",
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "3_5,2_5",
      "columns": [
        {
          "type": "3_5",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:gallery[0].text}}"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:gallery[0].text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:ink}}"
                  }
                }
              }
            },
            {
              "type": "divi/button",
              "module": "divi/button",
              "button_text": "{{slot:gallery[0].btn_text}}",
              "button_url": "{{slot:gallery[0].btn_url}}"
            }
          ]
        },
        {
          "type": "2_5",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "decoration": {
                "border": {
                  "desktop": {
                    "value": {
                      "radius": {
                        "topLeft": "20px",
                        "topRight": "20px",
                        "bottomRight": "20px",
                        "bottomLeft": "20px"
                      }
                    }
                  }
                }
              },
              "src": "{{slot:gallery[0].image}}",
              "alt": ""
            }
          ]
        }
      ]
    },
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "top": "0px"
              }
            }
          }
        }
      },
      "column_structure": "4_4",
      "columns": [
        {
          "type": "4_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            }
          ]
        }
      ]
    }
  ]
}