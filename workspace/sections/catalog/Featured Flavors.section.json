{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "rgba(253,251,247,0.39)",
          "image": {
            "url": "https://diviplus.io/wp-content/uploads/2020/06/food-background-business-hours.jpg?_t=1726125245",
            "size": "cover",
            "position": "center center",
            "repeat": "no-repeat",
            "parallax": {
              "enabled": "off"
            }
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "3_4,1_4",
      "columns": [
        {
          "type": "3_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "background": {
                  "desktop": {
                    "value": {
                      "color": "{{design:color:parchment-50}}"
                    }
                  }
                },
                "boxShadow": {
                  "desktop": {
                    "value": {
                      "style": "preset3",
                      "color": "rgba(26,24,20,0.1)"
                    }
                  }
                }
              }
            }
          ]
        },
        {
          "type": "1_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "title": "{{slot:features[0].title}}",
              "content": "<p><a href=\"tel:+000-000-0000\">000-000-0000</a></p>",
              "src": ""
            },
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "title": "{{slot:features[0].title}}",
              "content": "<p><a href=\"mailto:hello@example.com\">hello@example.com</a></p>",
              "src": ""
            },
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "title": "{{slot:features[0].title}}",
              "content": "<p>Street, City, State, Country</p>",
              "src": ""
            },
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            }
          ]
        }
      ]
    }
  ]
}