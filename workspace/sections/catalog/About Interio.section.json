{
  "type": "regular",
  "module": "divi/section",
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "top": "100px",
                "bottom": "80px"
              }
            }
          }
        }
      },
      "column_structure": "1_3,1_3,1_3",
      "columns": [
        {
          "type": "1_3",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "boxShadow": {
                  "desktop": {
                    "value": {
                      "style": "preset3",
                      "color": "rgba(26,24,20,0.1)"
                    }
                  }
                }
              }
            }
          ]
        },
        {
          "type": "1_3",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "src": "",
              "alt": ""
            }
          ]
        },
        {
          "type": "1_3",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "content": "{{slot:title}}",
              "level": "h2"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}"
            },
            {
              "type": "divi/button",
              "module": "divi/button",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "0px",
                        "bottom": "0px"
                      },
                      "margin": {
                        "top": "30px"
                      }
                    }
                  }
                }
              },
              "button_text": "{{slot:btn_primary_text}}",
              "button_url": "{{slot:btn_primary_url}}"
            }
          ]
        }
      ]
    }
  ]
}