{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "rgba(61,107,79,0.06)"
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "decoration": {
            "border": {
              "desktop": {
                "value": {
                  "radius": {
                    "topLeft": "5px",
                    "topRight": "5px",
                    "bottomRight": "5px",
                    "bottomLeft": "5px"
                  }
                }
              }
            }
          },
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "background": {
                  "desktop": {
                    "value": {
                      "color": "{{design:color:parchment-50}}"
                    }
                  }
                },
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "50px",
                        "right": "50px",
                        "bottom": "50px",
                        "left": "50px"
                      }
                    }
                  }
                }
              }
            }
          ]
        }
      ]
    }
  ]
}