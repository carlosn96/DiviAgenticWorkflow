{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "{{design:color:parchment-200}}"
        }
      }
    },
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "bottom": "0px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "bottom": "0px"
              }
            }
          }
        }
      },
      "column_structure": "1_4,1_2,1_4",
      "columns": [
        {
          "type": "1_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:stats[0].text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:accent}}"
                  }
                }
              }
            },
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "top": "30px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:stats[0].title}}",
              "level": "h2"
            },
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "background": {
                  "desktop": {
                    "value": {
                      "color": "{{design:color:parchment-50}}"
                    }
                  }
                },
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "top": "30px"
                      }
                    }
                  }
                }
              }
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "decoration": {
            "background": {
              "desktop": {
                "value": {
                  "gradient": {
                    "enabled": "on",
                    "type": "circular",
                    "direction": "180deg",
                    "overlaysImage": "on",
                    "stops": [
                      {
                        "color": "rgba(0,0,0,0.6)",
                        "position": "0%"
                      },
                      {
                        "color": "rgba(0,0,0,0)",
                        "position": "100%"
                      }
                    ]
                  }
                }
              }
            }
          },
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "src": "{{slot:stats[1].image}}",
              "alt": ""
            }
          ]
        },
        {
          "type": "1_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "src": "{{slot:stats[2].image}}",
              "alt": ""
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "top": "60px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:stats[2].text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:ink}}"
                  }
                }
              }
            }
          ]
        }
      ]
    }
  ]
}