{
  "type": "regular",
  "module": "divi/section",
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "top": "0px",
                "bottom": "0px"
              }
            }
          }
        }
      },
      "column_structure": "1_3,1_3,1_3",
      "columns": [
        {
          "type": "1_3",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "src": "{{slot:gallery[0].image}}",
              "alt": ""
            }
          ]
        },
        {
          "type": "1_3",
          "module": "divi/column",
          "decoration": {
            "background": {
              "desktop": {
                "value": {
                  "color": "{{design:color:parchment-300}}"
                }
              }
            },
            "spacing": {
              "desktop": {
                "value": {
                  "padding": {
                    "top": "40px",
                    "right": "40px",
                    "bottom": "40px",
                    "left": "40px"
                  }
                }
              }
            }
          },
          "modules": [
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "content": "{{slot:gallery[1].title}}",
              "level": "h2"
            },
            {
              "type": "divi/icon-list",
              "module": "divi/icon-list",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "top": "30px"
                      }
                    }
                  }
                }
              },
              "children": [
                {
                  "type": "divi/icon-list-item",
                  "module": "divi/icon-list-item",
                  "content": ""
                },
                {
                  "type": "divi/icon-list-item",
                  "module": "divi/icon-list-item",
                  "content": ""
                },
                {
                  "type": "divi/icon-list-item",
                  "module": "divi/icon-list-item",
                  "content": ""
                },
                {
                  "type": "divi/icon-list-item",
                  "module": "divi/icon-list-item",
                  "content": ""
                },
                {
                  "type": "divi/icon-list-item",
                  "module": "divi/icon-list-item",
                  "content": ""
                },
                {
                  "type": "divi/icon-list-item",
                  "module": "divi/icon-list-item",
                  "content": ""
                }
              ]
            }
          ]
        },
        {
          "type": "1_3",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "src": "{{slot:gallery[2].image}}",
              "alt": ""
            }
          ]
        }
      ]
    }
  ]
}