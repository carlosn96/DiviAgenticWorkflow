              "content": "<p><a href=\"tel:+000-000-0000\">+000-000-0000</a><br /><a href=\"tel:+000-000-0000\">+000-000-0000</a></p>",
              "src": ""
            }
          ]
        }
      ]
    },
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "top": "30px",
                "bottom": "30px"
              }
