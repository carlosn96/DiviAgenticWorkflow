              "content": "<a href=\"mailto:hello@example.com\">hello@example.com</a>\n<a href=\"mailto:demo@example.com\">demo@example.com</a>",
              "src": ""
            }
          ]
        },
        {
          "type": "1_3",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
