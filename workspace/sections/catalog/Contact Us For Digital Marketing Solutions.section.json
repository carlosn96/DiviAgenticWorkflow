{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "{{design:color:parchment-50}}"
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "decoration": {
            "background": {
              "desktop": {
                "value": {
                  "color": "{{design:color:parchment-200}}"
                }
              }
            },
            "spacing": {
              "desktop": {
                "value": {
                  "padding": {
                    "top": "80px",
                    "right": "50px",
                    "bottom": "80px",
                    "left": "50px"
                  }
                }
              }
            },
            "border": {
              "desktop": {
                "value": {
                  "radius": {
                    "topLeft": "5px",
                    "topRight": "5px",
                    "bottomRight": "5px",
                    "bottomLeft": "5px"
                  }
                }
              }
            },
            "boxShadow": {
              "desktop": {
                "value": {
                  "style": "preset1",
                  "color": "rgba(26,24,20,0.1)"
                }
              }
            }
          },
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "5px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "size": "15px"
                  }
                }
              }
            },
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "content": "{{slot:title}}",
              "level": "h2"
            },
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "border": {
                  "desktop": {
                    "value": {
                      "radius": {
                        "topLeft": "3px",
                        "topRight": "3px",
                        "bottomRight": "3px",
                        "bottomLeft": "3px"
                      }
                    }
                  }
                },
                "boxShadow": {
                  "desktop": {
                    "value": {
                      "style": "preset1",
                      "color": "rgba(166,124,64,0.07)"
                    }
                  }
                }
              }
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "decoration": {
            "spacing": {
              "desktop": {
                "value": {
                  "padding": {
                    "top": "80px",
                    "right": "80px",
                    "bottom": "80px",
                    "left": "80px"
                  }
                }
              }
            }
          },
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "5px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "size": "15px"
                  }
                }
              }
            },
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "content": "{{slot:title}}",
              "level": "h2"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}"
            },
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "title": "Address",
              "content": "<p><span> Street, City, State, Country</span></p>",
              "src": ""
            },
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "title": "Email",
              "content": "<p>info@example.com</p>",
              "src": ""
            },
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "title": "Phone",
              "content": "<p>000-000-0000</p>",
              "src": ""
            },
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            }
          ]
        }
      ]
    }
  ]
}