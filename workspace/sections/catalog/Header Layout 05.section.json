{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "rgba(26,24,20,0.6)",
          "image": {
            "url": "https://diviplus.io/wp-content/uploads/2019/11/cs-header-bg.webp?_t=1732190021",
            "size": "cover",
            "position": "center center",
            "repeat": "no-repeat",
            "parallax": {
              "enabled": "off"
            }
          }
        }
      }
    },
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "30px",
            "bottom": "0px"
          }
        }
      }
    },
    "boxShadow": {
      "desktop": {
        "value": {
          "style": "preset3",
          "color": "rgba(26,24,20,0.08)"
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "background": {
          "desktop": {
            "value": {
              "color": "rgba(253,251,247,0.43)"
            }
          }
        },
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "top": "18px",
                "bottom": "10px"
              }
            }
          }
        }
      },
      "column_structure": "1_5,1_5,1_5,1_5,1_5",
      "columns": [
        {
          "type": "1_5",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "top": "0px",
                        "bottom": "0px"
                      }
                    }
                  }
                }
              }
            }
          ]
        }
      ]
    }
  ]
}