{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "{{design:color:parchment-50}}"
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:gallery[0].text}}"
            },
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "background": {
                  "desktop": {
                    "value": {
                      "color": "{{design:color:parchment-50}}"
                    }
                  }
                },
                "border": {
                  "desktop": {
                    "value": {
                      "radius": {
                        "topLeft": "5px",
                        "topRight": "5px",
                        "bottomRight": "5px",
                        "bottomLeft": "5px"
                      }
                    }
                  }
                },
                "boxShadow": {
                  "desktop": {
                    "value": {
                      "style": "preset1"
                    }
                  }
                }
              }
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "decoration": {
                "border": {
                  "desktop": {
                    "value": {
                      "radius": {
                        "topLeft": "10px",
                        "topRight": "10px",
                        "bottomRight": "10px",
                        "bottomLeft": "10px"
                      }
                    }
                  }
                },
                "boxShadow": {
                  "desktop": {
                    "value": {
                      "style": "preset3",
                      "color": "rgba(26,24,20,0.1)"
                    }
                  }
                }
              },
              "src": "{{slot:gallery[1].image}}",
              "alt": ""
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "background": {
                  "desktop": {
                    "value": {
                      "gradient": {
                        "enabled": "on",
                        "type": "circular",
                        "direction": "180deg",
                        "overlaysImage": "on",
                        "stops": [
                          {
                            "color": "rgba(166,124,64,0.8)",
                            "position": "0%"
                          },
                          {
                            "color": "rgba(253,251,247,0.0)",
                            "position": "100%"
                          }
                        ]
                      }
                    }
                  }
                }
              },
              "content": "{{slot:gallery[1].text}}"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "background": {
                  "desktop": {
                    "value": {
                      "gradient": {
                        "enabled": "on",
                        "type": "circular",
                        "direction": "180deg",
                        "overlaysImage": "on",
                        "stops": [
                          {
                            "color": "rgba(166,124,64,0.7)",
                            "position": "0%"
                          },
                          {
                            "color": "rgba(253,251,247,0.0)",
                            "position": "100%"
                          }
                        ]
                      }
                    }
                  }
                }
              },
              "content": "{{slot:gallery[1].text}}"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "background": {
                  "desktop": {
                    "value": {
                      "gradient": {
                        "enabled": "on",
                        "type": "circular",
                        "direction": "180deg",
                        "overlaysImage": "on",
                        "stops": [
                          {
                            "color": "rgba(61,107,79,0.7)",
                            "position": "0%"
                          },
                          {
                            "color": "rgba(253,251,247,0.0)",
                            "position": "100%"
                          }
                        ]
                      }
                    }
                  }
                }
              },
              "content": "{{slot:gallery[1].text}}"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "background": {
                  "desktop": {
                    "value": {
                      "gradient": {
                        "enabled": "on",
                        "type": "circular",
                        "direction": "180deg",
                        "overlaysImage": "on",
                        "stops": [
                          {
                            "color": "rgba(92,82,68,0.65)",
                            "position": "0%"
                          },
                          {
                            "color": "rgba(253,251,247,0.0)",
                            "position": "100%"
                          }
                        ]
                      }
                    }
                  }
                }
              },
              "content": "{{slot:gallery[1].text}}"
            }
          ]
        }
      ]
    }
  ]
}