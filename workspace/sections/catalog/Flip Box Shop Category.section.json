{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "rgba(253,251,247,0.95)"
        }
      }
    },
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "bottom": "6%"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "4_4",
      "columns": [
        {
          "type": "4_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "content": "{{slot:title}}",
              "level": "h2"
            }
          ]
        }
      ]
    },
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_4,1_2,1_4",
      "columns": [
        {
          "type": "1_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "title": "",
              "content": "",
              "src": ""
            },
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "title": "",
              "content": "",
              "src": ""
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "decoration": {
            "background": {
              "desktop": {
                "value": {
                  "image": {
                    "url": "https://diviplus.io/wp-content/uploads/2021/03/snow-cold-winter-ring-fros.jpg",
                    "size": "cover",
                    "position": "center center",
                    "repeat": "no-repeat",
                    "parallax": {
                      "enabled": "on"
                    }
                  }
                }
              }
            },
            "border": {
              "desktop": {
                "value": {
                  "radius": {
                    "topLeft": "8px",
                    "topRight": "8px",
                    "bottomRight": "8px",
                    "bottomLeft": "8px"
                  }
                }
              }
            }
          },
          "modules": [
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "30px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:title}}",
              "level": "h2"
            },
            {
              "type": "divi/button",
              "module": "divi/button",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "bottom": "50px"
                      }
                    }
                  }
                }
              },
              "button_text": "{{slot:btn_primary_text}}",
              "button_url": "{{slot:btn_primary_url}}"
            }
          ]
        },
        {
          "type": "1_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "title": "",
              "content": "",
              "src": ""
            },
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "title": "",
              "content": "",
              "src": ""
            }
          ]
        }
      ]
    }
  ]
}