{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "top": "0px",
            "bottom": "0px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "background": {
          "desktop": {
            "value": {
              "color": "{{design:color:ink-soft}}"
            }
          }
        },
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "top": "0px",
                "right": "0px",
                "bottom": "0px",
                "left": "0px"
              }
            }
          }
        }
      },
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "decoration": {
            "spacing": {
              "desktop": {
                "value": {
                  "padding": {
                    "top": "80px",
                    "right": "80px",
                    "bottom": "80px",
                    "left": "80px"
                  }
                }
              }
            }
          },
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "right": "0px",
                        "left": "0px"
                      }
                    }
                  }
                }
              }
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "decoration": {
            "background": {
              "desktop": {
                "value": {
                  "gradient": {
                    "enabled": "on",
                    "type": "linear",
                    "direction": "90deg",
                    "overlaysImage": "on",
                    "stops": [
                      {
                        "color": "rgba(0,0,0,0.6)",
                        "position": "0%"
                      },
                      {
                        "color": "rgba(0,0,0,0)",
                        "position": "100%"
                      }
                    ]
                  },
                  "image": {
                    "url": "https://diviplus.io/wp-content/uploads/2019/11/Flexile-Portfolio-Hero.webp",
                    "size": "cover",
                    "position": "center center",
                    "repeat": "no-repeat",
                    "parallax": {
                      "enabled": "off"
                    }
                  }
                }
              }
            },
            "spacing": {
              "desktop": {
                "value": {
                  "padding": {
                    "top": "80px",
                    "right": "80px",
                    "bottom": "80px",
                    "left": "80px"
                  }
                }
              }
            }
          },
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "10px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:gallery[0].text}}"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "60px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:gallery[0].text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:ink}}"
                  }
                }
              }
            },
            {
              "type": "divi/button",
              "module": "divi/button",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "10px",
                        "right": "30px",
                        "bottom": "10px",
                        "left": "30px"
                      }
                    }
                  }
                }
              },
              "button_text": "{{slot:gallery[0].btn_text}}",
              "button_url": "{{slot:gallery[0].btn_url}}"
            }
          ]
        }
      ]
    }
  ]
}