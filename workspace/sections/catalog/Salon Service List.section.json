{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "image": {
            "url": "https://themes.diviplus.io/salon/wp-content/uploads/2021/11/dp-salon-09.webp",
            "size": "cover",
            "position": "center center",
            "repeat": "no-repeat",
            "parallax": {
              "enabled": "off"
            }
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "20px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:features[0].title}}",
              "level": "h2"
            },
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "content": "{{slot:features[0].title}}",
              "level": "h2"
            },
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "background": {
                  "desktop": {
                    "value": {
                      "color": "{{design:color:parchment-50}}"
                    }
                  }
                },
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "50px",
                        "right": "50px",
                        "bottom": "50px",
                        "left": "50px"
                      }
                    }
                  }
                },
                "border": {
                  "desktop": {
                    "value": {
                      "radius": {
                        "topLeft": "10px",
                        "topRight": "10px",
                        "bottomRight": "10px",
                        "bottomLeft": "10px"
                      }
                    }
                  }
                },
                "boxShadow": {
                  "desktop": {
                    "value": {
                      "style": "preset1",
                      "color": "rgba(26,24,20,0.1)"
                    }
                  }
                }
              }
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": []
        }
      ]
    }
  ]
}