{
  "type": "regular",
  "module": "divi/section",
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "2_5,3_5",
      "columns": [
        {
          "type": "2_5",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "boxShadow": {
                  "desktop": {
                    "value": {
                      "style": "preset1",
                      "color": "rgba(26,24,20,0.2)"
                    }
                  }
                }
              }
            }
          ]
        },
        {
          "type": "3_5",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:team[0].text}}"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:team[0].text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:ink}}",
                    "size": "20px"
                  }
                }
              }
            }
          ]
        }
      ]
    }
  ]
}