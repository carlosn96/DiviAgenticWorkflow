{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "{{design:color:parchment-50}}"
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "background": {
                  "desktop": {
                    "value": {
                      "gradient": {
                        "enabled": "on",
                        "type": "linear",
                        "direction": "180deg",
                        "overlaysImage": "on",
                        "stops": [
                          {
                            "color": "rgba(26,24,20,0.4)",
                            "position": "0%"
                          },
                          {
                            "color": "rgba(26,24,20,0.4)",
                            "position": "100%"
                          }
                        ]
                      },
                      "image": {
                        "url": "https://diviplus.io/wp-content/uploads/2019/11/divi-plus-furniture-contact-hero-1.webp",
                        "size": "cover",
                        "position": "center center",
                        "repeat": "no-repeat",
                        "parallax": {
                          "enabled": "off"
                        }
                      }
                    }
                  }
                },
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "180px",
                        "bottom": "180px"
                      }
                    }
                  }
                }
              }
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "decoration": {
            "spacing": {
              "desktop": {
                "value": {
                  "padding": {
                    "right": "100px"
                  }
                }
              }
            }
          },
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "bottom": "30px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:text}}"
            },
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            }
          ]
        }
      ]
    }
  ]
}