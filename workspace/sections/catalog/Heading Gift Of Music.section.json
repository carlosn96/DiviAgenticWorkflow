{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "image": {
            "url": "https://diviplus.io/wp-content/uploads/2019/11/music-light-sunlight-concert-color-piano-21920-pxhere.com_.jpg",
            "size": "cover",
            "position": "center center",
            "repeat": "no-repeat",
            "parallax": {
              "enabled": "on"
            }
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "3_5,2_5",
      "columns": [
        {
          "type": "3_5",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "content": "{{slot:title}}",
              "level": "h2"
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "top": "-40px",
                        "bottom": "0px",
                        "left": "15px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:text}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:ink-soft}}",
                    "size": "26px"
                  }
                }
              }
            },
            {
              "type": "divi/text",
              "module": "divi/text",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "margin": {
                        "top": "30px"
                      }
                    }
                  }
                }
              },
              "content": "{{slot:eyebrow}}",
              "bodyFont": {
                "desktop": {
                  "value": {
                    "fontFamily": "{{design:font:body}}",
                    "color": "{{design:color:ink}}",
                    "size": "36px"
                  }
                }
              }
            }
          ]
        },
        {
          "type": "2_5",
          "module": "divi/column",
          "modules": []
        }
      ]
    }
  ]
}