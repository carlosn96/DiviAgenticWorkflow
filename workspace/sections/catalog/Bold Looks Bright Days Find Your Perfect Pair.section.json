{
  "type": "regular",
  "module": "divi/section",
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "color": "rgba(234,228,212,0.3)"
        }
      }
    },
    "spacing": {
      "desktop": {
        "value": {
          "padding": {
            "bottom": "0px"
          }
        }
      }
    }
  },
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "bottom": "0px"
              }
            }
          }
        }
      },
      "column_structure": "4_4",
      "columns": [
        {
          "type": "4_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/text",
              "module": "divi/text",
              "content": "{{slot:text}}"
            }
          ]
        }
      ]
    },
    {
      "type": "divi/row",
      "module": "divi/row",
      "decoration": {
        "background": {
          "desktop": {
            "value": {
              "gradient": {
                "enabled": "on",
                "type": "circular",
                "direction": "180deg",
                "overlaysImage": "on",
                "stops": [
                  {
                    "color": "rgba(0,0,0,0.6)",
                    "position": "0%"
                  },
                  {
                    "color": "rgba(0,0,0,0)",
                    "position": "100%"
                  }
                ]
              }
            }
          }
        },
        "spacing": {
          "desktop": {
            "value": {
              "padding": {
                "top": "0px",
                "bottom": "0px"
              }
            }
          }
        }
      },
      "column_structure": "1_4,1_2,1_4",
      "columns": [
        {
          "type": "1_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder",
              "decoration": {
                "spacing": {
                  "desktop": {
                    "value": {
                      "padding": {
                        "top": "0px",
                        "right": "0px",
                        "bottom": "0px",
                        "left": "0px"
                      }
                    }
                  }
                }
              }
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "decoration": {
                "layout": {
                  "desktop": {
                    "value": {
                      "textAlign": "center"
                    }
                  }
                }
              },
              "src": "{{slot:gallery[1].image}}",
              "alt": ""
            }
          ]
        },
        {
          "type": "1_4",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/image",
              "module": "divi/image",
              "decoration": {
                "border": {
                  "desktop": {
                    "value": {
                      "radius": {
                        "topLeft": "20px",
                        "topRight": "20px",
                        "bottomRight": "20px",
                        "bottomLeft": "20px"
                      }
                    }
                  }
                },
                "boxShadow": {
                  "desktop": {
                    "value": {
                      "style": "preset4",
                      "color": "rgba(92,82,68,0.36)"
                    }
                  }
                }
              },
              "src": "{{slot:gallery[2].image}}",
              "alt": ""
            }
          ]
        }
      ]
    }
  ]
}