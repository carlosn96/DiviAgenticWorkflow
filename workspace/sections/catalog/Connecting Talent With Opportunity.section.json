{
  "type": "regular",
  "module": "divi/section",
  "rows": [
    {
      "type": "divi/row",
      "module": "divi/row",
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            },
            {
              "type": "divi/placeholder",
              "module": "divi/placeholder"
            }
          ]
        },
        {
          "type": "1_2",
          "module": "divi/column",
          "modules": [
            {
              "type": "divi/heading",
              "module": "divi/heading",
              "content": "{{slot:features[0].title}}",
              "level": "h2"
            },
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "title": "{{slot:features[0].title}}",
              "content": "Our system identifies top candidates based on skills, experience.",
              "src": ""
            },
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "title": "{{slot:features[0].title}}",
              "content": "<p>Specialized recruitment services tailored for IT, healthcare, finance.</p>",
              "src": ""
            },
            {
              "type": "divi/blurb",
              "module": "divi/blurb",
              "title": "{{slot:features[0].title}}",
              "content": "Fill critical roles within days, not weeks, with our agile recruitment model.",
              "src": ""
            },
            {
              "type": "divi/button",
              "module": "divi/button",
              "button_text": "{{slot:features[0].btn_text}}",
              "button_url": "{{slot:features[0].btn_url}}"
            }
          ]
        }
      ]
    }
  ]
}