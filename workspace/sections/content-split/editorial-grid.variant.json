{
  "presets": ["section:hero-dark"],
  "decoration": {
    "spacing": {
      "desktop": { "value": { "padding": { "top": "140px", "bottom": "140px", "right": "96px", "left": "96px" } } },
      "tablet": { "value": { "padding": { "top": "96px", "bottom": "96px", "right": "48px", "left": "48px" } } },
      "phone": { "value": { "padding": { "top": "64px", "bottom": "64px", "right": "24px", "left": "24px" } } }
    },
    "scroll": {
      "desktop": { "value": "reveal" }
    }
  },
  "rows": [
    {
      "column_structure": "3_5,2_5",
      "columns": [
        {
          "type": "3_5",
          "decoration": {
            "spacing": {
              "desktop": { "value": { "padding": { "right": "64px" } } },
              "tablet": { "value": { "padding": { "right": "0" } } }
            }
          },
          "modules": [
            {
              "type": "divi/text",
              "presets": ["text:eyebrow-dark"],
              "decoration": {
                "animation": {
                  "desktop": { "value": { "style": "slide-up", "duration": "600ms", "delay": "0ms" } }
                }
              },
              "content": "<p>{{slot:eyebrow}}</p>"
            },
             {
              "type": "divi/heading",
              "presets": ["text:display-md-light"],
              "decoration": {
                "spacing": {
                  "desktop": { "value": { "padding": { "bottom": "24px" } } }
                },
                "animation": {
                  "desktop": { "value": { "style": "slide-up", "duration": "600ms", "delay": "150ms" } }
                }
              },
              "content": "<h2>{{slot:title}}</h2>"
            },
            {
              "type": "divi/text",
              "presets": ["text:lead"],
              "decoration": {
                "spacing": {
                  "desktop": { "value": { "padding": { "bottom": "24px" } } }
                },
                "animation": {
                  "desktop": { "value": { "style": "slide-up", "duration": "600ms", "delay": "300ms" } }
                }
              },
              "content": "<p>{{slot:text}}</p>"
            },
            {
              "type": "divi/text",
              "presets": ["text:body-md"],
              "bodyFont": {
                "body": { "font": { "desktop": { "value": { "color": "{{design:color:text-on-dark}}" } } } }
              },
              "decoration": {
                "animation": {
                  "desktop": { "value": { "style": "slide-up", "duration": "600ms", "delay": "450ms" } }
                }
              },
              "content": "<p>{{slot:body}}</p>"
            },
            {
              "type": "divi/button",
              "presets": ["module:btn-outline-light"],
              "decoration": {
                "animation": {
                  "desktop": { "value": { "style": "slide-up", "duration": "600ms", "delay": "600ms" } }
                }
              },
              "button_text": "{{slot:btn_primary_text}}",
              "button_url": "{{slot:btn_primary_url}}"
            }
          ]
        },
        {
          "type": "2_5",
          "decoration": {
            "animation": {
              "desktop": { "value": { "style": "fade", "duration": "1000ms", "delay": "200ms" } }
            }
          },
          "modules": [
            {
              "type": "divi/blurb",
              "presets": ["module:glass-card", "transform:hover-scale"],
              "decoration": {
                "scroll": {
                  "desktop": { "value": "parallax-up" }
                }
              },
              "title": "",
              "icon": "{{slot:media_icon}}",
              "content": "<p>{{slot:media_attribution}}</p>"
            }
          ]
        }
      ]
    }
  ]
}
