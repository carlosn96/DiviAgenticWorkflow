{
  "presets": ["section:hero-dark"],
  "decoration": {
    "background": {
      "desktop": {
        "value": {
          "overlay": {
            "gradient": "radial-gradient(ellipse at 30% 20%, rgba(120,100,80,0.15) 0%, transparent 60%)"
          }
        }
      }
    },
    "spacing": {
      "desktop": { "value": { "padding": { "top": "120px", "bottom": "120px", "right": "96px", "left": "96px" } } },
      "tablet": { "value": { "padding": { "top": "80px", "bottom": "80px", "right": "48px", "left": "48px" } } },
      "phone": { "value": { "padding": { "top": "56px", "bottom": "56px", "right": "24px", "left": "24px" } } }
    },
    "scroll": {
      "desktop": { "value": "reveal" }
    }
  },
  "rows": [
    {
      "column_structure": "1_2,1_2",
      "columns": [
        {
          "type": "1_2",
          "decoration": {
            "animation": {
              "desktop": { "value": { "style": "slide", "direction": "left", "duration": "800ms", "delay": "100ms" } }
            }
          },
          "modules": [
            {
              "type": "divi/text",
              "presets": ["text:eyebrow-dark"],
              "content": "<p>{{slot:eyebrow}}</p>"
            },
            {
              "type": "divi/heading",
              "presets": ["text:display-md-light"],
              "decoration": {
                "spacing": {
                  "desktop": { "value": { "padding": { "bottom": "24px" } } }
                }
              },
              "content": "<h2>{{slot:title}}</h2>"
            },
            {
              "type": "divi/text",
              "presets": ["text:lead"],
              "decoration": {
                "spacing": {
                  "desktop": { "value": { "padding": { "bottom": "24px" } } }
                }
              },
              "content": "<p>{{slot:text}}</p>"
            },
            {
              "type": "divi/text",
              "presets": ["text:body-md"],
              "bodyFont": {
                "body": { "font": { "desktop": { "value": { "color": "{{design:color:text-on-dark}}" } } } }
              },
              "content": "<p>{{slot:body}}</p>"
            }
          ]
        },
        {
          "type": "1_2",
          "decoration": {
            "animation": {
              "desktop": { "value": { "style": "slide", "direction": "right", "duration": "800ms", "delay": "200ms" } }
            }
          },
          "modules": [
            {
              "type": "divi/icon-list",
              "presets": [],
              "decoration": {
                "animation": {
                  "desktop": { "value": { "style": "fade", "duration": "600ms", "delay": "400ms" } }
                }
              },
              "icon": {
                "advanced": {
                  "color": { "desktop": { "value": "var(--gcid-sepia-300)" } },
                  "size": { "desktop": { "value": "18px" } }
                }
              },
              "_repeat": {
                "source": "items",
                "target": "children",
                "module_type": "divi/icon-list-item"
              },
              "modules": [
                {
                  "title": "{{slot:title}}",
                  "icon": { "unicode": "{{slot:icon}}" }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
