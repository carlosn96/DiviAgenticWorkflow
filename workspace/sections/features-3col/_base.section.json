{
  "presets": ["section:light"],
  "rows": [
    {
      "column_structure": "1_1",
      "columns": [
        {
          "type": "1_1",
          "decoration": {
            "spacing": {
              "desktop": { "value": { "max_width": "700px", "align": "center", "padding": { "bottom": "64px" } } },
              "tablet": { "value": { "padding": { "bottom": "40px" } } }
            }
          },
          "modules": [
            {
              "type": "divi/text",
              "presets": ["text:eyebrow-dark"],
              "decoration": {
                "spacing": {
                  "desktop": { "value": { "padding": { "bottom": "8px" } } }
                }
              },
              "content": "<p>{{slot:eyebrow}}</p>"
            },
            {
              "type": "divi/heading",
              "presets": ["text:display-md"],
              "content": "<h2>{{slot:title}}</h2>"
            },
            {
              "type": "divi/text",
              "presets": ["text:lead-dark"],
              "content": "<p>{{slot:text}}</p>"
            }
          ]
        }
      ]
    },
    {
      "column_structure": "1_3,1_3,1_3",
      "_repeat": {
        "source": "features",
        "target": "columns",
        "column_type": "1_3"
      },
      "modules": [
        {
          "type": "divi/blurb",
          "presets": ["module:feature-card", "transform:hover-lift"],
          "decoration": {},
          "title": "{{slot:title}}",
          "icon": "{{slot:icon}}",
          "content": "<p>{{slot:text}}</p>"
        }
      ]
    }
  ]
}
